<%!-- Host-supplied head extras (config :manhwa, :extra_head) — e.g. an
     OCR runtime (TesseractJs) that powers the optional smart auto-reader
     (per-panel word count → adaptive delay). The smart toggle no-ops
     when no OCR runtime is present. --%>
{@extra_head && apply(elem(@extra_head, 0), elem(@extra_head, 1), [%{}])}

<%!--
  Fresco 0.4 ScrollStrip reader — DOM <img> + native browser scroll.

  Visual + interaction parity with the production scroll reader
  (show.html.heex): same nav classes, same default-hidden behavior,
  same 4-zone tap pattern (default preset). What we deliberately
  drop because strip mode doesn't need them: scroll-speed buttons
  (native scroll inherits OS speed), annotate / comments toggles
  (phased in once Etcher 0.3 integration lands), page-padding
  slider (strip is always full-width), smart auto-reader.

  Production reader and /reader/fresco-scroll-test/... untouched.
--%>
<%!-- `object-fit: contain` is a safety net: when a source comes through
     without dimensions, fresco_strip_sources falls back to a 720x1080
     placeholder which fresco bakes into `aspect-ratio` on the <img>.
     If the real image's ratio differs, default object-fit:fill would
     squish the pixels. With contain, we get letterboxing until the JS
     `image-loaded` handler corrects the inline aspect-ratio. --%>
<style>
  /* `position: relative` is required for our snap-debug overlay lines —
     they're absolute-positioned children of the strip container and need
     to scroll naturally with content (the container's scrollable area
     becomes their containing block). */
  #fresco-strip-reader { position: relative; }

  /* Movie-player-style cursor hide: scroll flips
     `data-cursor-hidden="true"` (in the scroll listener) → cursor: none
     site-wide. The next mousemove flips it back. Mobile is a no-op. */
  #fresco-strip-shell[data-cursor-hidden="true"],
  #fresco-strip-shell[data-cursor-hidden="true"] * {
    cursor: none !important;
  }
  #fresco-strip-reader > [data-fresco-strip-img] { object-fit: contain; }

  /* iPhone dynamic island / notch: physically pull the shell up past
     the safe-area inset so its top edge sits at the very top of the
     screen (and panels inside draw under the dynamic island).
     Requires `viewport-fit=cover` in the root viewport meta — that
     makes env(safe-area-inset-top) report the notch height. */
  #fresco-strip-shell {
    position: fixed !important;
    left: 0;
    right: 0;
    top: calc(-1 * env(safe-area-inset-top, 0px));
    bottom: calc(-1 * env(safe-area-inset-bottom, 0px));
    padding: 0 !important;
  }
  #fresco-strip-reader {
    height: 100dvh;
    height: 100lvh;
    /* match shell extension so internal content fills full screen */
    height: calc(100lvh + env(safe-area-inset-top, 0px) + env(safe-area-inset-bottom, 0px));
  }

  /* Suppress browser selection / drag behavior on the reader's images
     and chrome. Rapid tap-snap or double-click on the tap zones would
     otherwise trigger image/text selection (the blue highlight), drag-
     image previews, and the iOS long-press callout — all undesirable
     while reading. Scoped to the images + container background only
     (not all descendants) so etcher's tooltip / toolbar / inputs stay
     interactive on touch devices. */
  #fresco-strip-reader > [data-fresco-strip-img],
  #fresco-strip-reader > [data-strip-chapter-divider] {
    user-select: none;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
    -webkit-user-drag: none;
  }
  #fresco-strip-reader [data-fresco-strip-img] { -webkit-user-drag: none; }

  /* Pencil button highlight when Etcher is in annotation mode. The
     etcher:mode-changed listener flips data-annotate-mode on the shell. */
  #fresco-strip-shell[data-annotate-mode="true"] [id^="strip-annotate-toggle"] {
    background: rgba(59, 130, 246, 0.18);
    color: rgb(59, 130, 246);
  }

  /* Hide Etcher's auto-added nav buttons (pencil + eye) in fresco's
     nav column. Our toolbar surfaces annotation-mode + comments-
     visibility instead, so all reader controls live in one place. */
  #fresco-strip-reader .fresco-nav button[title="Annotate"],
  #fresco-strip-reader .fresco-nav button[title="Hide annotations"],
  #fresco-strip-reader .fresco-nav button[title="Show annotations"] {
    display: none !important;
  }

  /* Etcher 0.4.1 stamps `data-strip` on its toolbar and ships its
     own `.etcher-toolbar[data-strip] { position: fixed }` rule, so
     no consumer override is needed. We only bump `bottom` to clear
     our page-indicator pill (etcher defaults to 16px, which would
     overlap the pill at 16px). */
  #fresco-strip-reader .etcher-toolbar[data-strip] { bottom: 56px; }

  /* Snap debugger overlay — see the JS section "Snap debug overlay". */
  #strip-debug-probe-line {
    position: fixed; left: 0; right: 0; height: 2px;
    background: rgba(250, 204, 21, 0.9);
    z-index: 35; pointer-events: none;
  }
  #strip-debug-next-line, #strip-debug-prev-line {
    position: absolute; left: 0; right: 0; height: 2px;
    pointer-events: none;
  }
  #strip-debug-next-line { background: rgba(34, 197, 94, 0.9); }
  #strip-debug-prev-line { background: rgba(239, 68, 68, 0.9); }
  .strip-debug-label {
    position: absolute; left: 8px;
    background: rgba(0, 0, 0, 0.7); color: #fff;
    padding: 2px 6px; border-radius: 3px;
    font: 10px/1.2 ui-monospace, SFMono-Regular, Menlo, monospace;
    pointer-events: none;
    white-space: nowrap;
  }
  #strip-debug-probe-line .strip-debug-label { top: 4px; }
  #strip-debug-next-line .strip-debug-label,
  #strip-debug-prev-line .strip-debug-label { top: 4px; }
</style>

<div id="fresco-strip-shell"
     class="fixed inset-0 bg-base-100"
     data-source={List.first(@series)}
     data-slug={series_slug(@series)}
     data-chapter={@chapter}
     data-csrf-token={Phoenix.Controller.get_csrf_token()}
     data-total-pages={@total_pages}
     data-resume-page={@resume_page}
     data-resume-fraction={@resume_fraction}
     data-transient-mode={if @transient_mode, do: "1", else: "0"}
     data-settings-base={@series_base}
     data-api-base={@api_base}
     data-proxy-url={@proxy_url}
     data-debug-log-url={@debug_log_url}
     data-gif-base={@gif_base || ""}
     data-prev-chapter-url={if @prev_chapter, do: url_join(@series_base, @prev_chapter), else: ""}
     data-next-chapter-url={if @next_chapter, do: url_join(@series_base, @next_chapter), else: ""}
     data-next-chapter-api={if @next_chapter, do: url_join(@api_base, @next_chapter) <> "/images", else: ""}>

  <%!-- Tap-zone visualization overlay — flashes the active zones
       for 1.5s after a preset change, matching the paged reader.
       pointer-events-none so it doesn't intercept scroll / tap. --%>
  <div id="strip-tap-zone-overlay" class="fixed inset-0 z-[100] pointer-events-none transition-opacity duration-500" style="opacity:0;"></div>

  <%!-- Mobile top bar — matches production classes exactly. Defaults
       to `hidden`; setNav("visible") swaps in `flex lg:hidden`. --%>
  <div class="reader-nav-mobile hidden flex-col fixed top-0 left-0 right-0 z-20 bg-base-100 px-3 py-2 gap-2">
    <div class="flex items-center justify-between">
      <a href={@series_url} class="btn btn-ghost min-h-[44px] min-w-[44px]" title="Home">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
      </a>
      <div class="flex items-center gap-1">
        <a :if={@prev_chapter} href={url_join(@series_base, @prev_chapter)} class="btn btn-soft text-xl min-h-[44px] min-w-[44px]" title="Previous chapter">«</a>
        <span id="strip-chapter-label-mobile" class="font-bold text-sm px-1">Ch. {@chapter}</span>
        <a :if={@next_chapter} href={url_join(@series_base, @next_chapter)} class="btn btn-soft text-xl min-h-[44px] min-w-[44px]" title="Next chapter">»</a>
      </div>
      <div class="flex items-center gap-0">
        <a href={@series_url} class="btn btn-ghost min-h-[44px]" title="Chapters">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
        </a>
      </div>
    </div>
    <div class="flex items-center justify-center gap-2">
      <button id="strip-annotate-toggle-mobile" class="btn btn-ghost btn-sm min-h-[48px] min-w-[48px]" title="Draw comment">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
      </button>
      <button id="strip-comments-toggle-mobile" class="btn btn-ghost btn-sm min-h-[48px] min-w-[48px]" title="Show/hide comments">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
      </button>
      <button id="strip-settings-btn-mobile" class="btn btn-ghost btn-sm min-h-[48px] min-w-[48px]" title="Settings">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
      </button>
    </div>
  </div>

  <%!-- Desktop sidebar — matches production classes exactly. Defaults
       to `hidden`; setNav("visible") swaps in `lg:flex`. --%>
  <div id="strip-desktop-sidebar" class="reader-nav-desktop hidden flex-col gap-2 items-center px-2 fixed top-1/2 right-3 -translate-y-1/2 z-20 bg-base-200/80 backdrop-blur-sm rounded-xl py-2">
    <a href={@series_url} class="btn btn-sm btn-ghost" title="Home">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
    </a>
    <a href={@series_url} class="btn btn-sm btn-ghost" title="All Chapters">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
    </a>
    <a :if={@prev_chapter} href={url_join(@series_base, @prev_chapter)} class="btn btn-sm btn-ghost" title="Previous chapter">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
    </a>
    <span id="strip-chapter-label-desktop" class="text-xs font-bold text-base-content/60">Ch. {@chapter}</span>
    <a :if={@next_chapter} href={url_join(@series_base, @next_chapter)} class="btn btn-sm btn-ghost" title="Next chapter">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
    </a>
    <button id="strip-annotate-toggle-desktop" class="btn btn-sm btn-ghost" title="Draw comment">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
    </button>
    <button id="strip-comments-toggle-desktop" class="btn btn-sm btn-ghost" title="Show/hide comments">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
    </button>
    <%!-- Scroll-speed controls (desktop only) — wheel multiplier.
         Dropped from mobile nav since touch scroll doesn't go through
         the wheel listener and the snap is the primary mobile input. --%>
    <span class="h-px w-7 bg-base-content/20 my-1"></span>
    <button id="strip-speed-down" class="btn btn-sm btn-ghost" title="Slower scroll">🐢</button>
    <span id="strip-speed-label" class="text-xs font-bold text-base-content/60">1x</span>
    <button id="strip-speed-up" class="btn btn-sm btn-ghost" title="Faster scroll">🐇</button>
    <span class="h-px w-7 bg-base-content/20 my-1"></span>
    <button id="strip-settings-btn-desktop" class="btn btn-sm btn-ghost" title="Settings">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
    </button>
  </div>

  <%!-- Settings modal — section order + visual styling match the
       production scroll reader. Skipped sections (not applicable to
       strip mode): page rotation, page padding. Auto reader is
       deferred to a later phase. --%>
  <dialog id="strip-settings-modal" class="modal">
    <div class="modal-box max-w-xs">
      <h3 class="font-bold text-lg mb-4">Settings</h3>

      <%!-- Reader switcher — Legacy (MangaReaderLive scroll) / Fresco
           (this strip-fresco template). Legacy link goes to the
           dedicated /reader/legacy/manga/... URL so scroll-mode users
           can fall back without the canonical URL bouncing them. --%>
      <div class="flex items-center justify-between mb-2">
        <p class="text-sm font-medium">Reader</p>
        <div class="flex gap-1">
          <a :if={@legacy_url} href={@legacy_url} class="btn btn-sm btn-outline" title="Open the legacy reader">Legacy</a>
          <span class="btn btn-sm btn-outline btn-active no-animation pointer-events-none">Fresco</span>
        </div>
      </div>

      <div class="border-t border-base-content/20 my-3"></div>

      <%!-- Reading mode — Scroll active; Paged form-POSTs the user's
           preferred mode and bounces back to the production reader. --%>
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm font-medium">Reading mode</p>
        <div class="flex gap-1">
          <span class="btn btn-sm btn-outline btn-active no-animation pointer-events-none">Scroll</span>
          <form method="post" action={"#{@series_base}/reading_mode"} class="mode-switch-form contents">
            <input type="hidden" name="_method" value="put" />
            <input type="hidden" name="_csrf_token" value={Phoenix.Controller.get_csrf_token()} />
            <input type="hidden" name="mode" value="paged" />
            <input type="hidden" name="device" value="" />
            <input type="hidden" name="redirect_to" value={@self_url} />
            <button type="submit" class="btn btn-sm btn-outline">Paged</button>
          </form>
        </div>
      </div>

      <%!-- Panel snap toggle — when off, tap zones still navigate but
           scroll by one viewport instead of snapping to gutters. --%>
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-sm font-medium">Panel snap</p>
          <p class="text-xs text-base-content/50">Snap to panel edges on tap</p>
        </div>
        <input type="checkbox" id="strip-panel-snap-toggle" class="toggle toggle-sm toggle-primary" />
      </div>

      <%!-- Show comments — toggles all Etcher annotation overlays. --%>
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-sm font-medium">Show comments</p>
          <p class="text-xs text-base-content/50">Hide annotation overlays on pages</p>
        </div>
        <input type="checkbox" id="strip-comments-visible" class="toggle toggle-sm toggle-primary" checked />
      </div>

      <%!-- Auto reader — timer-driven panel-snap navigation. Toggle
           on, pick delay, snap fires every N seconds. Pauses on any
           user interaction (scroll / touch / key); floating Resume
           button picks back up. Mirrors the legacy reader minus the
           OCR-driven adaptive delay (deferred). --%>
      <div id="strip-auto-reader-section" class="mb-4 pl-2 border-l-2 border-primary/20 space-y-3">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium">Auto reader</p>
            <p class="text-xs text-base-content/50">Auto-snap to next panel on a timer</p>
          </div>
          <input type="checkbox" id="strip-auto-reader-toggle" class="toggle toggle-sm toggle-primary" />
        </div>
        <div class="flex items-center justify-between">
          <p class="text-xs">Delay</p>
          <div class="flex items-center gap-2">
            <input type="range" id="strip-auto-reader-delay" min="1" max="20" step="1" class="range range-xs range-primary w-24" />
            <span id="strip-auto-reader-delay-label" class="text-xs font-mono w-7 text-right">5s</span>
          </div>
        </div>
        <div id="strip-auto-reader-smart-row" class="flex items-center justify-between">
          <div>
            <p class="text-xs">Smart</p>
            <p class="text-[10px] text-base-content/40">OCR adjusts delay per panel</p>
          </div>
          <input type="checkbox" id="strip-auto-reader-smart-toggle" class="toggle toggle-xs toggle-primary" />
        </div>
      </div>

      <%!-- Page padding — same control as the production scroll reader.
           Shrinks the rendered image width by `pct`% of the viewport
           (split evenly L/R via container padding) so a long-strip
           chapter is readable on desktop without scrolling a 1080-wide
           image at full bleed. Range 0-90, persisted per slug. --%>
      <div class="mb-4">
        <div class="flex items-center justify-between mb-1">
          <p class="text-sm font-medium">Page padding</p>
          <span id="strip-page-padding-label" class="text-xs font-mono">0%</span>
        </div>
        <input type="range" id="strip-page-padding-slider" min="0" max="90" step="1" value="0" class="range range-xs range-primary w-full" />
      </div>

      <%!-- Panel snap tuning (per-manga) — same controls as production's
           snap-config-section. Settings persist per slug in localStorage
           and feed into the gutter-detection algorithm. --%>
      <div id="strip-snap-config-section" class="mb-4 pl-2 border-l-2 border-primary/20 space-y-3">
        <p class="text-xs font-semibold text-base-content/50 uppercase tracking-wide">Panel snap tuning (this manga)</p>
        <div class="flex items-center justify-between">
          <p class="text-xs">Jump style</p>
          <div class="flex gap-1" id="strip-snap-jump-style-btns">
            <button type="button" data-value="smooth" class="btn btn-xs strip-snap-jump-btn">Smooth</button>
            <button type="button" data-value="instant" class="btn btn-xs strip-snap-jump-btn">Instant</button>
          </div>
        </div>
        <div class="flex items-center justify-between">
          <p class="text-xs">Scan distance</p>
          <select id="strip-snap-scan-distance" class="select select-bordered select-xs w-20">
            <option value="1">1x</option>
            <option value="2">2x</option>
            <option value="3">3x</option>
            <option value="4">4x</option>
            <option value="5">5x</option>
          </select>
        </div>
        <div class="flex items-center justify-between">
          <p class="text-xs">Long panel steps</p>
          <input type="checkbox" id="strip-snap-long-panel-steps" class="toggle toggle-xs toggle-primary" />
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs">Gutter tolerance</p>
            <p class="text-[10px] text-base-content/40">How forgiving the gutter detector is</p>
          </div>
          <select id="strip-snap-gutter-tolerance" class="select select-bordered select-xs w-28">
            <option value="50">Strict</option>
            <option value="300">Normal</option>
            <option value="800">Relaxed</option>
            <option value="1500">Aggressive</option>
          </select>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs">Min gutter width</p>
            <p class="text-[10px] text-base-content/40">Smallest band counted as a gutter</p>
          </div>
          <select id="strip-snap-min-gutter-width" class="select select-bordered select-xs w-28">
            <option value="20">Narrow</option>
            <option value="50">Normal</option>
            <option value="100">Wide</option>
          </select>
        </div>
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs">Merge close gutters</p>
            <p class="text-[10px] text-base-content/40">Glue bands separated by &lt; N source-px</p>
          </div>
          <select id="strip-snap-gutter-merge-gap" class="select select-bordered select-xs w-28">
            <option value="0">Off</option>
            <option value="75">Light</option>
            <option value="150">Normal</option>
            <option value="300">Aggressive</option>
          </select>
        </div>
        <button type="button" id="strip-snap-config-reset" class="btn btn-xs btn-ghost text-error w-full">Reset to defaults</button>
      </div>

      <%!-- Tap zone layout — 3 presets, matching production. Click a
           card to switch; the highlighted card shows the active preset. --%>
      <div class="mb-2">
        <p class="text-sm font-medium mb-2">Tap zones</p>
        <div class="flex flex-row gap-2">
          <label class="cursor-pointer flex flex-col items-center gap-1.5 p-2 rounded-lg border-2 flex-1 strip-tap-preset-card" data-preset="default">
            <input type="radio" name="strip_tap_preset" value="default" class="hidden" />
            <div class="relative w-16 aspect-[3/4] rounded border border-base-content/20 overflow-hidden bg-base-300">
              <div class="absolute top-0 left-0 bottom-0 w-1/3 bg-green-500/30 flex items-center justify-center text-green-900 font-bold text-[7px] border-r border-green-500/40">N</div>
              <div class="absolute top-0 right-0 bottom-0 w-1/3 bg-green-500/30 flex items-center justify-center text-green-900 font-bold text-[7px] border-l border-green-500/40">N</div>
              <div class="absolute top-0 left-1/3 right-1/3 h-1/2 bg-blue-500/30 flex items-center justify-center text-blue-900 font-bold text-[7px] border-b border-blue-500/40">M</div>
              <div class="absolute bottom-0 left-1/3 right-1/3 h-1/2 bg-red-500/30 flex items-center justify-center text-red-900 font-bold text-[7px] border-t border-red-500/40">P</div>
            </div>
            <span class="text-xs font-medium">Default</span>
          </label>
          <label class="cursor-pointer flex flex-col items-center gap-1.5 p-2 rounded-lg border-2 flex-1 strip-tap-preset-card" data-preset="left_right">
            <input type="radio" name="strip_tap_preset" value="left_right" class="hidden" />
            <div class="relative w-16 aspect-[3/4] rounded border border-base-content/20 overflow-hidden bg-base-300">
              <div class="absolute top-0 left-0 bottom-0 w-1/3 bg-red-500/30 flex items-center justify-center text-red-900 font-bold text-[7px] border-r border-red-500/40">P</div>
              <div class="absolute top-0 right-0 bottom-0 w-1/3 bg-green-500/30 flex items-center justify-center text-green-900 font-bold text-[7px] border-l border-green-500/40">N</div>
              <div class="absolute inset-0 left-1/3 right-1/3 bg-blue-500/30 flex items-center justify-center text-blue-900 font-bold text-[7px]">M</div>
            </div>
            <span class="text-xs font-medium">Left / Right</span>
          </label>
          <label class="cursor-pointer flex flex-col items-center gap-1.5 p-2 rounded-lg border-2 flex-1 strip-tap-preset-card" data-preset="right_left">
            <input type="radio" name="strip_tap_preset" value="right_left" class="hidden" />
            <div class="relative w-16 aspect-[3/4] rounded border border-base-content/20 overflow-hidden bg-base-300">
              <div class="absolute top-0 left-0 bottom-0 w-1/3 bg-green-500/30 flex items-center justify-center text-green-900 font-bold text-[7px] border-r border-green-500/40">N</div>
              <div class="absolute top-0 right-0 bottom-0 w-1/3 bg-red-500/30 flex items-center justify-center text-red-900 font-bold text-[7px] border-l border-red-500/40">P</div>
              <div class="absolute inset-0 left-1/3 right-1/3 bg-blue-500/30 flex items-center justify-center text-blue-900 font-bold text-[7px]">M</div>
            </div>
            <span class="text-xs font-medium">Right / Left</span>
          </label>
        </div>
        <p class="text-xs text-base-content/50 mt-2">N = next panel · P = previous · M = menu</p>
      </div>

      <%!-- Debug section — separated from the user-facing toggles so
           diagnostic stuff (snap-quality probe, future surfaces) is
           clearly out-of-band. --%>
      <div class="border-t border-base-content/20 my-3"></div>
      <p class="text-xs font-medium text-base-content/50 mb-2 uppercase tracking-wide">Debug</p>

      <%!-- Snap debugger — when on, surfaces a 👍/👎 verdict bar after
           each snap settles. Verdict + landing state is POSTed to
           /reader/api/fresco-debug-log so we can grep /tmp/fresco_debug.log
           to dial in the snap algorithm based on labeled samples. --%>
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-sm font-medium">Snap debugger</p>
          <p class="text-xs text-base-content/50">Rate each snap good/bad after it lands</p>
        </div>
        <input type="checkbox" id="strip-snap-debug-toggle" class="toggle toggle-sm toggle-primary" />
      </div>

      <div class="modal-action">
        <button class="btn btn-sm" onclick="document.getElementById('strip-settings-modal').close()">Close</button>
      </div>
    </div>
    <div class="modal-backdrop" onclick="document.getElementById('strip-settings-modal').close()"></div>
  </dialog>

  <FrescoStrip.viewer
    id="fresco-strip-reader"
    sources={strip_sources(@images, @proxy_url)}
    class="w-full h-lvh"
    theme={:inherit}
    view_tracking={true}
    extensions={%{"etcher" => %{"version" => "1", "annotations" => @etcher_annotations}}}
  />

  <%!-- Bottom-center page indicator — updated via the scroll_strip's
       `viewport-change` event so it tracks the dominant image as the
       user scrolls. Matches production strip's progress pill. --%>
  <div id="strip-page-indicator"
       class="fixed bottom-4 left-1/2 -translate-x-1/2 z-10 px-3 py-1 rounded-full bg-base-300/70 text-xs font-bold text-base-content/70 pointer-events-none">
    1 / {length(@images)}
  </div>

  <%!-- Auto-reader resume button — hidden by default; shows when the
       user pauses auto-reader by scrolling / touching / tapping a key.
       Same placement + style as the legacy reader. --%>
  <button id="strip-auto-reader-resume"
          class="hidden fixed bottom-20 right-4 z-30 btn btn-lg bg-base-300/80 backdrop-blur border-none shadow-lg gap-2">
    <span class="text-lg">▶</span> Resume
  </button>

  <%!-- Pointer-lock gesture mode (desktop only). Click → browser hides
       the cursor; we map vertical mouse movement to window.scrollBy
       so the user can flick the strip up/down with the mouse alone.
       Click anywhere (or Escape) to release. --%>
  <button id="mouse-gesture-btn" type="button"
          class="hidden lg:flex fixed bottom-4 right-4 z-30 btn btn-sm btn-circle bg-base-300/70 hover:bg-base-300 border-0"
          title="Mouse gesture navigation (click here, then move mouse to scroll — click again to exit)">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M9 6l3-3 3 3M9 18l3 3 3-3M6 9l-3 3 3 3M18 9l3 3-3 3" />
    </svg>
  </button>
  <div id="mouse-gesture-banner"
       class="hidden fixed bottom-14 right-4 z-40 px-2 py-1 rounded-full bg-primary text-primary-content text-[11px] font-semibold shadow-lg pointer-events-none">
    ↑ ↓ · click to exit
  </div>

  <%!-- Etcher shape-drawn composer (strip mode). Same layout as the
       paged reader's composer (textarea + GIF picker + private
       toggle). EtcherHostLive pushes `etcher:open-composer` after
       any shape commit; on Post we hit /marks/etcher-shapes/:uuid/comment
       and then openCommentModal for the comment thread. --%>
  <dialog id="etcher-composer" class="modal" data-shape-uuid="">
    <div class="modal-box max-w-sm p-3">
      <%!-- Font ≥16px on mobile so iOS Safari doesn't auto-zoom on
           focus (and trap us at the zoomed scale). Drops back to
           text-sm at the lg breakpoint where desktop fits more text. --%>
      <textarea id="etcher-composer-content"
                rows="3"
                class="textarea textarea-bordered w-full text-base lg:text-sm"
                placeholder="Add a comment..."
                maxlength="2000"></textarea>
      <div id="etcher-composer-gif-preview" class="hidden mt-1 relative">
        <img class="max-w-full rounded-lg" />
        <button type="button" id="etcher-composer-gif-remove"
                class="absolute top-1 right-1 bg-black/60 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs">✕</button>
      </div>
      <div id="etcher-composer-error" class="hidden text-xs text-error mt-1"></div>
      <div class="flex items-center gap-2 mt-2">
        <button type="button" id="etcher-composer-gif-btn"
                class="btn btn-sm btn-ghost px-2 font-bold min-h-[2rem]"
                style="border:1px solid color-mix(in oklch, var(--color-base-content) 20%, transparent);">GIF</button>
      </div>
      <div id="etcher-composer-gif-picker" class="hidden mt-2"></div>
      <label class="flex items-center gap-2 mt-2 cursor-pointer text-xs text-base-content/60">
        <input type="checkbox" id="etcher-composer-private" class="checkbox checkbox-xs" />
        <span class="flex items-center gap-1">🔒 Private</span>
      </label>
      <div class="flex gap-2 mt-3">
        <button type="button" id="etcher-composer-post" class="btn btn-sm btn-primary flex-1">Post</button>
        <button type="button" id="etcher-composer-cancel" class="btn btn-sm btn-ghost flex-1">Cancel</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
  <%!-- Etcher annotation overlay — wrapped in the configured etcher-host
       LiveView so the hook gets a channel for `etcher:annotations-changed` /
       `etcher:shape-drawn`. The pencil buttons in the nav call
       `window.Etcher.layerFor("fresco-strip-reader").toggleMode()` to
       open the bottom toolbar. Renders nothing when no etcher host is
       configured (config :manhwa, :etcher_host). --%>
  <%= if @etcher_host do %>
    {Phoenix.Component.live_render(@conn, @etcher_host,
      id: "etcher-host-fresco-strip-reader",
      session: @etcher_session)}
  <% end %>

  <%!-- Snap verdict bar — controlled entirely from JS. Hidden until
       the debugger toggle is on AND a snap has just settled. Tapping
       a button POSTs the labeled sample; the bar then hides. --%>
  <div id="strip-snap-verdict-bar"
       class="hidden fixed bottom-3 left-1/2 -translate-x-1/2 z-40 bg-base-300/95 backdrop-blur-sm rounded-full shadow-lg px-2 py-1.5 flex items-center gap-2">
    <span class="text-xs font-medium px-2 text-base-content/70">Snap?</span>
    <button id="strip-snap-verdict-good"
            class="btn btn-sm btn-circle btn-success"
            title="Good (g)">👍</button>
    <button id="strip-snap-verdict-bad"
            class="btn btn-sm btn-circle btn-error"
            title="Bad (b)">👎</button>
    <button id="strip-snap-verdict-skip"
            class="btn btn-sm btn-circle btn-ghost"
            title="Skip">✕</button>
  </div>
</div>

<script>
  (() => {
    // ============================================================
    // Panel snap module — pixel-space gutter detection (same algorithm
    // as production / OSD-based test reader) + native container
    // scrollTo for the snap motion.
    // ============================================================
    // Constants that don't come from per-manga config. Margin is the
    // top/bottom % of each image we ignore when detecting bands (so a
    // half-rendered top border doesn't count as a gutter). The rest of
    // the algorithm parameters live in `snapConfig` and mirror
    // production's defaultScrollConfig exactly.
    const MARGIN_PCT = 0.03;

    // Capture deep-link `?ann=<etcher_shape_uuid>` up here, before any
    // handlers can fire — fresco_strip's viewport-change listener calls
    // `history.replaceState` to rewrite the URL to the canonical chapter
    // path, which strips ?ann= once the dominant image settles. Stashing
    // the uuid synchronously keeps the deep-link handler + resume-scroll
    // suppress reading the same source of truth.
    const ANN_DEEPLINK_UUID = new URLSearchParams(window.location.search).get("ann");

    // Storage keys — `:<slug>` suffix for per-manga settings, no
    // suffix for global ones.
    const SHELL    = document.getElementById("fresco-strip-shell");
    const SLUG     = SHELL?.dataset?.slug || "_";
    const NAV_KEY  = "fresco-strip-test:nav-visible";
    const SNAP_ON_KEY    = "fresco-strip-test:panel-snap-on:" + SLUG;
    const SNAP_CFG_KEY   = "fresco-strip-test:snap-config:"   + SLUG;
    const TAP_PRESET_KEY = "fresco-strip-test:tap-preset:"    + SLUG;
    const PADDING_KEY    = "fresco-strip-test:padding-pct:"   + SLUG;
    const DEBUG_KEY      = "fresco-strip-test:snap-debug-on";

    // Default per-manga config — matches production's
    // defaultScrollConfig (line ~924 in show.html.heex).
    const DEFAULT_SNAP_CONFIG = {
      jump_style:        "smooth",   // "smooth" | "instant"
      scan_distance:     3,          // 1-5, multiplied by viewport height
      long_panel_steps:  true,       // bool, half-step for tall panels
      gutter_tolerance:  300,        // luminance variance threshold
      min_gutter_width:  50,         // source-pixel debounce
      // Source-px gap below which two consecutive detected bands are
      // merged into a single logical gutter. Real-world gutters often
      // contain a thin strip of dark content in the middle (panel
      // number, page indicator, watermark, dialogue overflow). The
      // variance detector then sees two separate white bands; without
      // merging, snap can land in the gap between them — feels like
      // landing mid-gutter. 150px catches most observed cases. 0 = no
      // merge (= old behavior, in case the merge hides a real panel).
      gutter_merge_gap:  150
    };

    function loadSnapConfig() {
      try {
        const raw = localStorage.getItem(SNAP_CFG_KEY);
        if (!raw) return { ...DEFAULT_SNAP_CONFIG };
        return Object.assign({}, DEFAULT_SNAP_CONFIG, JSON.parse(raw));
      } catch (_) { return { ...DEFAULT_SNAP_CONFIG }; }
    }
    function saveSnapConfig(cfg) {
      try { localStorage.setItem(SNAP_CFG_KEY, JSON.stringify(cfg)); } catch (_) {}
    }
    let snapConfig = loadSnapConfig();
    let panelSnapEnabled = localStorage.getItem(SNAP_ON_KEY) !== "false"; // default ON

    // Scroll-speed multiplier — separate desktop / mobile profiles
    // matching the legacy reader. Multiplies the no-snap tap-fallback
    // distance and the mouse-wheel deltaY. Always live (regardless of
    // snap on/off) so the user can dial scroll feel either way.
    const SPEED_LEVELS_DESKTOP = [0.25, 0.5, 0.75, 1, 1.5, 2, 3, 5, 7.5, 10];
    const SPEED_LABELS_DESKTOP = ["0.25x", "0.5x", "0.75x", "1x", "1.5x", "2x", "3x", "5x", "7.5x", "10x"];
    const SPEED_LEVELS_MOBILE  = [0.25, 0.5, 0.75, 1, 1.25, 1.5, 1.75, 2, 2.25, 2.5, 2.75, 3];
    const SPEED_LABELS_MOBILE  = ["0.25x", "0.5x", "0.75x", "1x", "1.25x", "1.5x", "1.75x", "2x", "2.25x", "2.5x", "2.75x", "3x"];
    const SPEED_DEFAULT_DESKTOP = 3;
    const SPEED_DEFAULT_MOBILE  = 3;
    const SPEED_KEY_DESKTOP = "fresco-strip-test:speed-desktop";
    const SPEED_KEY_MOBILE  = "fresco-strip-test:speed-mobile";
    let speedIdxDesktop = parseInt(localStorage.getItem(SPEED_KEY_DESKTOP) ?? SPEED_DEFAULT_DESKTOP, 10);
    let speedIdxMobile  = parseInt(localStorage.getItem(SPEED_KEY_MOBILE)  ?? SPEED_DEFAULT_MOBILE,  10);
    if (isNaN(speedIdxDesktop) || speedIdxDesktop < 0 || speedIdxDesktop >= SPEED_LEVELS_DESKTOP.length) speedIdxDesktop = SPEED_DEFAULT_DESKTOP;
    if (isNaN(speedIdxMobile)  || speedIdxMobile  < 0 || speedIdxMobile  >= SPEED_LEVELS_MOBILE.length)  speedIdxMobile  = SPEED_DEFAULT_MOBILE;
    function currentSpeedMultiplier() {
      return window.innerWidth < 1024
        ? SPEED_LEVELS_MOBILE[speedIdxMobile]
        : SPEED_LEVELS_DESKTOP[speedIdxDesktop];
    }
    function setSpeedDesktop(i) {
      i = Math.max(0, Math.min(i, SPEED_LEVELS_DESKTOP.length - 1));
      speedIdxDesktop = i;
      localStorage.setItem(SPEED_KEY_DESKTOP, String(i));
      const lbl = document.getElementById("strip-speed-label");
      if (lbl) lbl.textContent = SPEED_LABELS_DESKTOP[i];
    }
    function setSpeedMobile(i) {
      i = Math.max(0, Math.min(i, SPEED_LEVELS_MOBILE.length - 1));
      speedIdxMobile = i;
      localStorage.setItem(SPEED_KEY_MOBILE, String(i));
      const lbl = document.getElementById("strip-speed-label-mobile");
      if (lbl) lbl.textContent = SPEED_LABELS_MOBILE[i];
    }
    document.getElementById("strip-speed-up")?.addEventListener("click", () => setSpeedDesktop(speedIdxDesktop + 1));
    document.getElementById("strip-speed-down")?.addEventListener("click", () => setSpeedDesktop(speedIdxDesktop - 1));
    document.getElementById("strip-speed-up-mobile")?.addEventListener("click", () => setSpeedMobile(speedIdxMobile + 1));
    document.getElementById("strip-speed-down-mobile")?.addEventListener("click", () => setSpeedMobile(speedIdxMobile - 1));
    // Init labels.
    setSpeedDesktop(speedIdxDesktop);
    setSpeedMobile(speedIdxMobile);

    const COMMENTS_VISIBLE_KEY = "fresco-strip-test:comments-visible:" + SLUG;
    let commentsVisible = localStorage.getItem(COMMENTS_VISIBLE_KEY) !== "false"; // default ON
    let tapPreset = localStorage.getItem(TAP_PRESET_KEY) || "default";
    // Debugger defaults OFF — must be opted into per session because it
    // covers part of the screen and triggers HTTP requests on every snap.
    let snapDebugOn = localStorage.getItem(DEBUG_KEY) === "true";

    // Page padding — desktop default 70 (matches production), mobile 0.
    // The slider value is the shrink-amount %, split evenly L/R as
    // container padding so the strip imgs (width:100%) reflow narrower
    // and the side bands stay tappable (tap-zone math uses the full
    // container rect, so side gutters trigger the same zones).
    // Default page padding 0 on both mobile + desktop. The desktop
    // 70% default conflicts with Etcher's strip overlay (which sizes
    // to container width via width:100%, not to the actual img). The
    // user can opt into padding via the settings slider; until
    // Etcher upstream supports padded layouts, default is "no
    // padding".
    const PADDING_DEFAULT = 0;
    let currentPadding = (function() {
      const raw = localStorage.getItem(PADDING_KEY);
      if (raw === null) return PADDING_DEFAULT;
      const n = parseInt(raw, 10);
      if (isNaN(n) || n < 0 || n > 90) return PADDING_DEFAULT;
      return n;
    })();

    // 3 production-default tap-zone presets.
    const TAP_ZONE_PRESETS = {
      default:    { leftThird: "next", rightThird: "next", midTop: "menu", midBottom: "prev" },
      left_right: { leftThird: "prev", rightThird: "next", midTop: "menu", midBottom: "menu" },
      right_left: { leftThird: "next", rightThird: "prev", midTop: "menu", midBottom: "menu" }
    };

    const gutterCache = new Map();
    const detecting   = new Map();
    // idx → <img> element memo for imgEl(). Element identity per idx
    // never changes (memory windowing only clears `src`, chapter
    // append only adds new idxs), so entries never go stale; the
    // isConnected check in imgEl is a pure safety net. Module scope —
    // not inside whenReady — so the hoisted imgEl can run during the
    // mount sweep without hitting a const TDZ.
    const imgElCache = new Map();

    // Bound the gutter cache so multi-chapter reading doesn't accumulate
    // Float32Array rowMean/rowVar buffers without limit. Per-entry cost
    // is ~2·h floats (32-64KB for a tall manhwa image), so without a cap
    // 3-4 chapters of reading puts 10+MB of typed-array data on the JS
    // heap and GC pauses start affecting snap timing. Insertion-order
    // FIFO matches forward-reading: the oldest entries are the ones the
    // user already passed, and re-analyzing them on a rare backscroll is
    // cheap compared to the steady-state slowdown a uncapped cache
    // produces.
    const GUTTER_CACHE_MAX = 60;
    // ocrCache entries are tiny (a small array of word counts per panel)
    // but per-entry has no upper bound for very tall images. Cap matches
    // gutter cap so the two stay roughly in step as the user reads.
    const OCR_CACHE_MAX = 80;
    function trimMapToCap(map, cap) {
      while (map.size > cap) {
        const first = map.keys().next().value;
        if (first === undefined) break;
        map.delete(first);
      }
    }

    // ── OCR (TesseractJs) ────────────────────────────────────────────
    // Per-panel word count for the smart auto-reader. Mirrors the
    // legacy reader (show.html.heex), keyed by strip source idx
    // instead of <img> element.
    //
    // SAFETY: OCR is triggered ONLY from `image-loaded` and from the
    // Smart toggle change handler. Never from rAF or scroll, since
    // canvas + worker.recognize stall the main thread enough to perturb
    // snap timing. Jobs are serialized through `ocrSerialChain` so we
    // never run two recognize() calls in parallel (worker pool stalls).
    const ocrCache = new Map();
    const ocrInFlight = new Set();
    let ocrSerialChain = Promise.resolve();

    function ocrStorageKey(url) { return "ocr-strip:" + url; }
    function loadOcrFromStorage(url) {
      try {
        const raw = localStorage.getItem(ocrStorageKey(url));
        if (!raw) return null;
        const e = JSON.parse(raw);
        if (e && Array.isArray(e.panelWordCounts)) return e;
      } catch (_) {}
      return null;
    }
    function saveOcrToStorage(url, panelWordCounts) {
      try {
        localStorage.setItem(ocrStorageKey(url), JSON.stringify({
          panelWordCounts, ts: Date.now()
        }));
      } catch (_) {}
    }
    // Drop OCR entries older than 30 days.
    (function cleanupOcrStorage() {
      try {
        const maxAge = 30 * 24 * 60 * 60 * 1000;
        const now = Date.now();
        const toRemove = [];
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (k && k.startsWith("ocr-strip:")) {
            try {
              const e = JSON.parse(localStorage.getItem(k));
              if (!e || !e.ts || (now - e.ts) > maxAge) toRemove.push(k);
            } catch (_) { toRemove.push(k); }
          }
        }
        toRemove.forEach(k => localStorage.removeItem(k));
      } catch (_) {}
    })();

    // window.TesseractJs is loaded via deferred <script> tag; wait up to ~3s.
    function getOcrWorker() {
      function wait(remaining) {
        if (window.TesseractJs) return window.TesseractJs.getOcrWorker().catch(() => null);
        if (remaining <= 0) return Promise.resolve(null);
        return new Promise((r) => setTimeout(r, 100)).then(() => wait(remaining - 1));
      }
      return wait(30);
    }

    function computeDensity(wordCount) {
      if (wordCount <= 0) return 0;
      return Math.min(Math.sqrt(wordCount / 50), 1);
    }

    function loadImage(url) {
      return new Promise((resolve) => {
        const im = new Image();
        im.onload  = () => resolve(im);
        im.onerror = () => resolve(null);
        im.src = url;
      });
    }

    // Shared "does this row look like real content" predicate — used
    // by band merging AND the phase-2 noise skip so the two can never
    // disagree about what counts as a panel.
    //
    // A row is content when it's genuinely dark (mean < 200 — real
    // text/art ink) OR carries sustained structure (variance above
    // 2× the gutter tolerance — pale art, gradients, screentone all
    // clear this at full-resolution detection; JPEG noise and band-
    // edge spikes stay under it). A gap counts as real content only
    // on a run of ≥ 8 consecutive content rows or >15% content rows
    // overall — single-row spikes (page numbers, dust, block edges)
    // don't survive either test.
    const GAP_CONTENT_MEAN     = 200;
    const GAP_CONTENT_VAR_MULT = 2;
    const GAP_CONTENT_RUN      = 8;
    const GAP_CONTENT_FRACTION = 0.15;
    function gapHasRealContent(rowMean, rowVar, fromIy, toIy, tolerance) {
      if (!rowMean) return false;
      const varTol = (tolerance || 300) * GAP_CONTENT_VAR_MULT;
      let run = 0, contentRows = 0;
      const total = toIy - fromIy;
      for (let iy = fromIy; iy < toIy; iy++) {
        const content =
          rowMean[iy] < GAP_CONTENT_MEAN || (rowVar && rowVar[iy] > varTol);
        if (content) {
          contentRows++;
          if (++run >= GAP_CONTENT_RUN) return true;
        } else {
          run = 0;
        }
      }
      return total > 0 && contentRows / total > GAP_CONTENT_FRACTION;
    }

    function detectGuttersInImage(img) {
      const w = img.naturalWidth, h = img.naturalHeight;
      if (!w || !h) return { bands: [], w: 0, h: 0 };
      const x0 = Math.floor(w * 0.1);
      const stripW = Math.floor(w * 0.9) - x0;
      if (stripW < 5) return { bands: [], w, h };
      // Full-resolution rows, legacy-style sparse columns. The legacy
      // reader's reliability came from probing native-resolution pixel
      // rows (sampling every 4th pixel across the row); the previous
      // 0.25×/0.125× downscale here AVERAGED pixels instead, which
      // crushed variance — soft textures inside panels started
      // classifying as gutters and thin structure vanished — while the
      // tolerance (300) stayed tuned for the native-res signal.
      //
      // Every source row is analyzed exactly (band edges are vertical
      // features, so vertical fidelity is what alignment depends on),
      // columns are sampled every 4th pixel like legacy's isWhiteBand
      // (sampling ≠ averaging: it preserves the variance signal).
      // Processing runs in ≤1024-row slices through one reusable
      // canvas, which bounds transient getImageData buffers to a few
      // MB and stays far under iOS's canvas-area limit for very tall
      // strips.
      const SLICE = 1024;
      const c = document.createElement("canvas");
      c.width = stripW;
      c.height = Math.min(SLICE, h);
      const ctx = c.getContext("2d", { willReadFrequently: true });
      const isWhite = new Uint8Array(h);
      const rowMean = new Float32Array(h);
      const rowVar  = new Float32Array(h);
      const tolerance = snapConfig.gutter_tolerance;
      const colStride = 16; // every 4th RGBA pixel — matches legacy
      // Pass 1: per-row mean/variance. Flatness alone is NOT enough to
      // call a row a gutter — a soft blurred panel opening (uniform
      // dark scene, defocused establishing shot) is just as flat as
      // real page background, and variance-only detection extended
      // bands INTO such panels, making snaps land visibly inside the
      // art instead of at its edge. Gutter classification therefore
      // happens in pass 2 against the image's estimated background.
      for (let sy = 0; sy < h; sy += SLICE) {
        const sh = Math.min(SLICE, h - sy);
        let rgba;
        // null = transient canvas failure (e.g. live img evicted mid-
        // draw) — caller retries later instead of caching empty bands.
        try {
          ctx.drawImage(img, x0, sy, stripW, sh, 0, 0, stripW, sh);
          rgba = ctx.getImageData(0, 0, stripW, sh).data;
        } catch (_) { return null; }
        const rowBytes = stripW * 4;
        for (let dy = 0; dy < sh; dy++) {
          const rowOff = dy * rowBytes;
          let sum = 0, sumSq = 0, n = 0;
          for (let i = 0; i < rowBytes; i += colStride) {
            const lum = 0.299 * rgba[rowOff + i] + 0.587 * rgba[rowOff + i + 1] + 0.114 * rgba[rowOff + i + 2];
            sum += lum; sumSq += lum * lum; n++;
          }
          if (!n) continue;
          const mean = sum / n;
          const variance = sumSq / n - mean * mean;
          const y = sy + dy;
          rowMean[y] = mean;
          rowVar[y]  = variance;
        }
      }
      // Pass 2: estimate the page background as the median brightness
      // of the flat rows, then classify gutters as flat AND background-
      // colored. White-page chapters get bg ≈ 250 (dark flat panel
      // rows stop counting as gutter — the fix above); black-page
      // flashback chapters get a dark bg per image, so their black
      // gutters keep working. Mixed backgrounds within one image
      // resolve to the dominant one — the rare minority-color gutter
      // degrades to a plain scroll step rather than a bad landing.
      const BG_MATCH = 48;
      const flatMeans = [];
      for (let y = 0; y < h; y++) {
        if (rowVar[y] <= tolerance) flatMeans.push(rowMean[y]);
      }
      flatMeans.sort((a, b) => a - b);
      const bg = flatMeans.length ? flatMeans[flatMeans.length >> 1] : 255;
      for (let y = 0; y < h; y++) {
        isWhite[y] =
          rowVar[y] <= tolerance && Math.abs(rowMean[y] - bg) <= BG_MATCH ? 1 : 0;
      }
      // min_gutter_width is in source pixels (matches production).
      const minBandRows = Math.max(2, snapConfig.min_gutter_width);
      const margin      = Math.floor(h * MARGIN_PCT);
      const bands = [];
      let bandStart = -1;
      for (let y = margin; y < h - margin; y++) {
        if (isWhite[y]) {
          if (bandStart === -1) bandStart = y;
        } else {
          if (bandStart !== -1 && (y - bandStart) >= minBandRows) {
            bands.push([bandStart, y]);
          }
          bandStart = -1;
        }
      }
      if (bandStart !== -1 && ((h - margin) - bandStart) >= minBandRows) {
        bands.push([bandStart, h - margin]);
      }
      const merged = mergeCloseBands(
        bands, snapConfig.gutter_merge_gap || 0, rowMean, rowVar, tolerance
      );
      return { bands: merged, rawBands: bands, rowMean, rowVar, bg, w, h };
    }

    // Merge consecutive bands separated by less than `gapThreshold`
    // source-px into one — but ONLY when the gap carries no real
    // content. The old unconditional merge could glue two tight
    // gutters ACROSS a small panel or SFX between them, and the phase
    // walk then landed past it. gapHasRealContent (dark rows OR
    // sustained variance) keeps small/pale panels un-swallowed.
    function mergeCloseBands(bands, gapThreshold, rowMean, rowVar, tolerance) {
      if (!bands || bands.length < 2 || gapThreshold <= 0) return bands.slice();
      const out = [bands[0].slice()];
      for (let i = 1; i < bands.length; i++) {
        const prev = out[out.length - 1];
        const cur = bands[i];
        if (
          cur[0] - prev[1] < gapThreshold &&
          !gapHasRealContent(rowMean, rowVar, prev[1], cur[0], tolerance)
        ) {
          prev[1] = cur[1];
        } else {
          out.push(cur.slice());
        }
      }
      return out;
    }

    // Set inside whenReady once imgEl exists — lets detection reuse the
    // already-decoded strip <img> instead of re-fetching + re-decoding
    // the bitmap through a fresh Image(). The bytes are usually in the
    // HTTP cache either way; the decode of a tall manhwa strip is the
    // expensive part and the live element already paid it.
    let liveImgLookup = null;
    // Set inside whenReady — called with (idx, w, h) whenever detection
    // learns an image's true dimensions, so placeholder dims get
    // corrected the moment they're knowable instead of waiting for the
    // lazy <img> load. See onDimsDetected for why that matters.
    let onDimsDetected = null;
    async function gutterFor(idx, sources) {
      if (gutterCache.has(idx)) return gutterCache.get(idx);
      if (detecting.has(idx))   return detecting.get(idx);
      const src = sources[idx];
      if (!src) return { bands: [], w: 0, h: 0 };
      const p = (async () => {
        try {
          // Yield one macrotask first: gutterFor is often called
          // fire-and-forget in loops (prewarm, scan-range warm) and
          // the live-img path below does its canvas work synchronously
          // — without the yield a warm loop would block the tap-to-
          // snap path for several detections of main-thread time.
          await new Promise((r) => setTimeout(r, 0));
          let result = null;
          const live = liveImgLookup ? liveImgLookup(idx) : null;
          if (live && live.complete && live.naturalWidth > 0) {
            result = detectGuttersInImage(live);
          }
          if (!result) {
            const im = await loadImage(src.url);
            if (im) result = detectGuttersInImage(im);
          }
          if (!result) {
            // Canvas/decode failure is transient — return empty WITHOUT
            // caching so a later call can retry. (Previously a failed
            // load settled into `detecting` forever and the image never
            // got bands.)
            return { bands: [], w: 0, h: 0 };
          }
          gutterCache.set(idx, result);
          trimMapToCap(gutterCache, GUTTER_CACHE_MAX);
          if (result.w && result.h && onDimsDetected) onDimsDetected(idx, result.w, result.h);
          return result;
        } finally {
          detecting.delete(idx);
        }
      })();
      detecting.set(idx, p);
      return p;
    }

    function whenReady(cb) {
      if (window.Fresco && window.Fresco.onViewerReady) {
        window.Fresco.onViewerReady("fresco-strip-reader", cb);
      } else {
        setTimeout(() => whenReady(cb), 50);
      }
    }

    whenReady((handle) => {
      const container = handle.container;
      const sources = JSON.parse(container.dataset.sources);
      // Wire the module-scope detection helper to this closure's imgEl
      // (hoisted function declaration, so this is safe at the top) —
      // from here on gutterFor can reuse already-decoded strip imgs.
      liveImgLookup = (idx) => imgEl(idx);
      // Gutter detection decodes the real bitmap, so it learns the true
      // dims BEFORE the lazy <img> element loads. Sync them into
      // sources[] + the img's aspect-ratio immediately (same moves as
      // correctAspect). Without this, every display↔source mapping for
      // a prewarmed-but-not-yet-loaded image runs through placeholder
      // dims (1000×1500) while its bands are in the true frame (often
      // 800×8000) — snap targets land deep inside the wrong panel, and
      // the layout shift correctAspect would apply later lands mid-
      // snap-animation instead of now, before the user arrives.
      onDimsDetected = (idx, w, h) => {
        const src = sources[idx];
        if (!src || (src.width === w && src.height === h)) return;
        src.width  = w;
        src.height = h;
        const el = imgEl(idx);
        if (el) el.style.aspectRatio = w + " / " + h;
        invalidateImgPositions();
        // Same synthetic resize correctAspect fires — Etcher re-reads
        // fresco's getImages() to re-sync overlay viewBoxes.
        window.dispatchEvent(new Event("resize"));
      };

      // iOS Safari hides the URL bar when the document body scrolls.
      // Our strip uses container-internal scroll, so the bar normally
      // stays visible and leaves a white strip at the top (the bar's
      // background). Body is set to min-height: 100lvh + 1px, so the
      // nudge below actually has somewhere to scroll. Try a few times
      // — some iOS versions ignore programmatic scroll until after
      // the first paint or a touch.
      function nudgeUrlBarAway() {
        window.scrollTo(0, 1);
        if (window.scrollY < 1) window.scrollTo(0, 100);
      }
      requestAnimationFrame(nudgeUrlBarAway);
      setTimeout(nudgeUrlBarAway, 100);
      setTimeout(nudgeUrlBarAway, 500);
      // Also retry the first time the user touches the container —
      // iOS Safari often dismisses the bar on first user gesture.
      container.addEventListener("touchstart", nudgeUrlBarAway, { once: true, passive: true });

      // ── Page progress indicator ───────────────────────────────────
      // Updates the bottom-center pill on every viewport-change event
      // (fresco's scroll_strip fires this when the dominant visible
      // image changes). Matches the production strip's progress pill.
      const stripIndicator = document.getElementById("strip-page-indicator");
      function updateStripIndicator() {
        if (!stripIndicator) return;
        // Prefer the multi-chapter snapshot so the indicator stays tied
        // to the CURRENT chapter as more chapters auto-append. Old
        // "X / sources.length" grew unboundedly as we appended.
        // Wrapped in try/catch because snapshotMultiChapterState
        // references `loadedChapters` (declared later in the same
        // scope) — calls early in init hit the TDZ.
        let st = null;
        try {
          if (typeof snapshotMultiChapterState === "function") {
            st = snapshotMultiChapterState();
          }
        } catch (_) { /* loadedChapters not initialized yet */ }
        if (st && st.totalPages > 0) {
          const readPct = ((st.page - 1 + st.fraction) / st.totalPages) * 100;
          const leftPct = Math.max(0, Math.min(100, Math.round(100 - readPct)));
          stripIndicator.textContent = leftPct + "% left · Ch. " + st.chapter;
        } else {
          stripIndicator.textContent = "—";
        }
      }
      handle.on("viewport-change", updateStripIndicator);
      // Scroll-driven refresh so the % advances smoothly within a page
      // — viewport-change only fires when the dominant image changes.
      let stripIndRaf = false;
      container.addEventListener("scroll", () => {
        if (stripIndRaf) return;
        stripIndRaf = true;
        requestAnimationFrame(() => {
          stripIndRaf = false;
          updateStripIndicator();
        });
      }, { passive: true });

      // ── Idle prescan ──────────────────────────────────────────────
      function schedulePrescan(idx) {
        if (gutterCache.has(idx) || detecting.has(idx)) return;
        const ric = window.requestIdleCallback || ((cb) => setTimeout(cb, 100));
        ric(() => { gutterFor(idx, sources); });
      }

      // Eager prewarm of [startIdx, startIdx+count): kicks off gutter
      // detection (and OCR when smart-reader is on) immediately so the
      // next few snaps find their data already cached and don't stall
      // on first-tap. Idempotent — gutterFor / enqueueOcr both dedupe.
      //
      // Sized to cover both findSnapTargetCore (scans scan_distance vh
      // forward) and findPanelEnd (scans scan_distance vh forward from
      // the *target*) — a single tap can touch up to ~2·scan_distance
      // images ahead of the current dominant one. Under-sizing makes
      // the await chain inside findSnapTarget stall on cold gutters,
      // which is exactly the lag we're trying to eliminate.
      const PREWARM_AHEAD = Math.max(3, ((snapConfig.scan_distance || 3) * 2) + 1);
      function prewarmAhead(startIdx, count) {
        const end = Math.min(startIdx + count, sources.length);
        for (let i = Math.max(0, startIdx); i < end; i++) {
          gutterFor(i, sources);
          try {
            if (arSmart) {
              const el = imgEl(i);
              if (el && el.complete && el.naturalWidth > 0) enqueueOcr(i);
            }
          } catch (_) { /* arSmart not yet initialized at mount-time call */ }
        }
      }

      // ── Aspect-ratio correction ───────────────────────────────────
      // Server-side ImageDimensions.probe can fail (HEAD blocked, range
      // unsupported, format not recognized) — in that case the source
      // entry comes through with placeholder 720x1080 dims. Fresco
      // bakes that into `aspect-ratio` on the <img>, which would squish
      // the actual image (especially long-strip manhwa, easily 800x4000).
      // When the real load completes, override the inline aspect-ratio
      // to match the natural pixels AND update the sources[i] cache so
      // panel-snap math (which uses sources[i].height to map display→
      // source pixels) reads from real dims, not placeholders.
      function correctAspect(idx) {
        const el = imgEl(idx);
        if (!el) return;
        const nw = el.naturalWidth, nh = el.naturalHeight;
        if (!nw || !nh) return;
        const src = sources[idx];
        if (!src) return;
        // Only correct when dims actually differ — avoids touching style
        // for the common case where the probe was correct.
        if (src.width === nw && src.height === nh) return;
        el.style.aspectRatio = nw + " / " + nh;
        src.width  = nw;
        src.height = nh;
        // Etcher 0.4.1's _applyStripOverlayLayout re-reads
        // fresco's getImages() on window resize, so a synthetic
        // resize tells the overlay to pick up the corrected
        // viewBox + position now that natural dims are known.
        window.dispatchEvent(new Event("resize"));
      }

      handle.on("image-loaded", (e) => {
        correctAspect(e.imageIdx);
        // An aspect correction can change this img's height and shift
        // every later img's offsetTop, so the position snapshot used
        // by snap math is now stale.
        invalidateImgPositions();
        // Kick off gutter detection directly instead of via
        // schedulePrescan's requestIdleCallback — RIC often never
        // fires during active reading, so prescan would never
        // actually run and the user's first snap into the new image
        // would await a cold detection (the half-second stall the
        // user reported). gutterFor is async + deduped by `detecting`,
        // so this is fire-and-forget and one-shot per image.
        gutterFor(e.imageIdx, sources);
        maybeResumeScroll(e.imageIdx);
      });
      // Server-rendered imgs may have already fired `load` by the time
      // the hook attaches. Sweep what's already complete on mount.
      for (let i = 0; i < sources.length; i++) {
        const el = imgEl(i);
        if (el && el.complete && el.naturalWidth > 0) correctAspect(i);
      }
      prewarmAhead(0, PREWARM_AHEAD);

      // ── Reading-time + progress persistence ───────────────────────
      // Activity-based gap accounting — same model the legacy reader
      // (lib/.../manga_html/show.html.heex) used. Every interaction
      // event (scroll, touch, key, pointer) calls recordActivity,
      // which adds the gap since the previous activity to the
      // chapter timer — capped at 45 s per gap so a single idle
      // gap can't credit hours. In strip mode this is the right
      // unit because a single image (a tall manhwa panel) routinely
      // takes minutes to read; per-image-dwell capping would clip
      // legitimate slow scroll-reading.
      const GAP_CAP_MS = 45_000;
      const PROGRESS_DEBOUNCE_MS = 500;
      let chapterElapsedMs = 0;
      let lastActivityAt = performance.now();
      let saveTimer = null;

      // ── Transient mode (comment deep-link arrivals) ────────────────
      // Mirrors the paged reader: `?ann=` arrivals gate progress saves
      // until the user proves they're actually rereading (≥2 min on
      // page AND ≥2 page transitions). In strip mode, "page transition"
      // is the dominant-image index changing — counted by
      // `markPageTransition` below. Promotion zeroes accumulated time
      // so peeking minutes don't get rolled into the reading session.
      let transientMode = SHELL.dataset.transientMode === "1";
      const transientStartMs = Date.now();
      const TRANSIENT_TIME_MS = 120_000;
      const TRANSIENT_FLIPS = 2;
      let pageTransitionCount = 0;

      function markPageTransition() {
        pageTransitionCount++;
        if (!transientMode) return;
        // First viewport-change is the initial dominant-image settle
        // (landing), not a real flip — subtract 1 so the threshold
        // counts user-driven transitions only.
        const flips = Math.max(0, pageTransitionCount - 1);
        const elapsed = Date.now() - transientStartMs;
        if (elapsed >= TRANSIENT_TIME_MS && flips >= TRANSIENT_FLIPS) {
          transientMode = false;
          chapterElapsedMs = 0;
        }
      }

      function recordActivity() {
        const now = performance.now();
        const gap = now - lastActivityAt;
        chapterElapsedMs += Math.min(GAP_CAP_MS, Math.max(0, gap));
        lastActivityAt = now;
      }

      // Original-chapter image count, captured before any appends.
      // Fresco's strip-mode memory windowing covers indices 0..N-1
      // (the imgs it knows about); we run our own windowing for
      // appended-chapter imgs (idx ≥ originalChapterCount) so a long
      // auto-load session doesn't pin every chapter's bitmap in RAM.
      const originalChapterCount = sources.length;

      // ── Multi-chapter inline append ────────────────────────────────
      // Track every chapter that's been loaded into this scroll
      // container. Initial entry: the chapter the page was loaded with.
      // When the user scrolls within 2 viewports of the bottom, fetch
      // the next chapter's images and append them directly into the
      // same container (with a divider header) so reading is
      // uninterrupted.
      //
      // Each chapter's images get a `data-chapter` attribute so the
      // dominant-img scan can route progress saves to the right
      // chapter regardless of how many chapters are loaded. URL is
      // kept in sync via `history.replaceState` whenever the
      // dominant chapter changes.
      const loadedChapters = [{
        chapter: SHELL.dataset.chapter,
        startIdx: 0,
        endIdx: sources.length - 1,
        count: sources.length,
        nextChapterApi: SHELL.dataset.nextChapterApi || ""
      }];
      container.querySelectorAll("[data-fresco-strip-img]").forEach((img) => {
        if (!img.hasAttribute("data-chapter")) img.setAttribute("data-chapter", SHELL.dataset.chapter);
      });

      // Tell the embedded EtcherHostLive which global image_idx ranges
      // belong to which chapter, so its etcher:annotations-changed
      // handler can split a single emit across multiple MangaMark rows
      // (one per chapter) and rebase each shape's image_idx to its
      // chapter-local frame. Without this, shapes drawn during
      // auto-load save under the URL chapter with global image_idx —
      // invisible on reopen because the chapter doesn't have an
      // overlay at that idx.
      function dispatchEtcherLoadedChapters() {
        if (!loadedChapters.length || loadedChapters[0].endIdx < 0) return;
        const chapters = loadedChapters.map((c) => ({
          chapter: c.chapter,
          start_idx: c.startIdx,
          end_idx: c.endIdx
        }));
        window.dispatchEvent(new CustomEvent("etcher-loaded-chapters", {
          detail: { chapters }
        }));
      }
      // CommentBridge's mounted() pings this event on attach so we
      // re-dispatch if our initial fire raced the bridge mount.
      window.addEventListener("etcher-bridge-ready", dispatchEtcherLoadedChapters);
      dispatchEtcherLoadedChapters();
      let loadingNextChapter = false;
      let loadingDivider = null;
      let lastObservedChapter = SHELL.dataset.chapter;

      function showLoadingDivider() {
        if (!loadingDivider) {
          loadingDivider = document.createElement("div");
          loadingDivider.className = "w-full text-center py-6 text-base-content/40 text-sm";
          loadingDivider.textContent = "Loading next chapter…";
        }
        container.appendChild(loadingDivider);
      }
      function hideLoadingDivider() {
        if (loadingDivider && loadingDivider.parentNode) loadingDivider.remove();
      }
      function appendChapterToContainer(chapterName, images, nextApi) {
        const last = loadedChapters[loadedChapters.length - 1];
        const baseIdx = last.endIdx + 1;
        // Chapter header — clearly marks the boundary.
        const header = document.createElement("div");
        header.className = "w-full text-center py-6 text-base-content/50 font-bold text-sm border-t border-base-content/15 mt-6";
        header.textContent = "Chapter " + chapterName;
        header.setAttribute("data-strip-chapter-divider", chapterName);
        container.appendChild(header);
        images.forEach((img, i) => {
          const idx = baseIdx + i;
          const rawUrl = (img && img.url) || img;
          const w = (img && img.width) || 1000;
          const h = (img && img.height) || 1500;
          // Match fresco_strip_sources/1: store + render through the
          // image proxy so source-CDN cross-origin / referer rules
          // don't break us. Both the IMG element AND the `sources`
          // entry use the SAME proxied URL — the gutter-detection
          // `loadImage(src.url)` call needs the proxied URL to fetch
          // image bytes (raw CDN URLs typically reject our origin),
          // otherwise snap would see zero gutters past the original
          // chapter and stop working.
          const proxiedUrl = SHELL.dataset.proxyUrl + "?" + new URLSearchParams({ url: rawUrl }).toString();
          const el = document.createElement("img");
          el.src = proxiedUrl;
          el.setAttribute("data-src", proxiedUrl);
          el.setAttribute("data-fresco-strip-img", "");
          el.setAttribute("data-image-idx", String(idx));
          el.setAttribute("data-chapter", chapterName);
          el.alt = "";
          el.loading = "lazy";
          el.decoding = "async";
          el.style.cssText = "display: block; width: 100%; aspect-ratio: " + w + " / " + h + ";";
          // fresco_strip only attaches its "load" listener to imgs
          // present at init, so appended-chapter imgs never fire
          // `image-loaded` and the wrapping aspect-ratio correction
          // never runs — when the server's reported w/h is wrong (probe
          // failed, hit the placeholder fallback), the img ends up
          // letterboxed by `object-fit: contain` and looks zoomed out.
          // Mirror the original-img code path manually.
          el.addEventListener("load", () => {
            correctAspect(idx);
            invalidateImgPositions();
          });
          container.appendChild(el);
          sources.push({ url: proxiedUrl, width: w, height: h });
          // Browser cache can resolve the request fast enough that
          // `load` already fired by the time the listener attached;
          // sweep right after to cover that race.
          if (el.complete && el.naturalWidth > 0) {
            correctAspect(idx);
            invalidateImgPositions();
          }
        });
        loadedChapters.push({
          chapter: chapterName,
          startIdx: baseIdx,
          endIdx: baseIdx + images.length - 1,
          count: images.length,
          nextChapterApi: nextApi
        });
        // Re-sync chapter ranges with EtcherHostLive so shapes drawn
        // on the freshly-appended chapter route to its own row, not
        // the URL chapter's, and with the correct chapter-local
        // image_idx.
        dispatchEtcherLoadedChapters();
        // New imgs change container scrollHeight and contribute new
        // top/h entries, so any cached snapshot is now incomplete.
        invalidateImgPositions();
        // Warm gutter detection for the first few new imgs so snap
        // kicks in without a stall when the user crosses into the new
        // chapter. Eager (not idle) so the data is ready by the time
        // the user reaches it.
        prewarmAhead(baseIdx, PREWARM_AHEAD);
      }
      async function fetchAndAppendNextChapter() {
        if (loadingNextChapter) return;
        const last = loadedChapters[loadedChapters.length - 1];
        if (!last.nextChapterApi) return;
        loadingNextChapter = true;
        showLoadingDivider();
        try {
          const resp = await fetch(last.nextChapterApi, { credentials: "same-origin" });
          if (!resp.ok) return;
          const data = await resp.json();
          if (!Array.isArray(data.images) || data.images.length === 0) return;
          hideLoadingDivider();
          const nextApi = data.next_chapter
            ? SHELL.dataset.apiBase + "/" + encodeURIComponent(data.next_chapter) + "/images"
            : "";
          const baseIdxBeforeAppend = last.endIdx + 1;
          appendChapterToContainer(data.chapter, data.images, nextApi);
          // Tell fresco_strip about the new specs so it (a) tracks them
          // in its internal `sources` array (used by `getImages()`'s
          // fallback when an `<img>`'s natural dims aren't yet known)
          // and (b) attaches `load` listeners that re-emit
          // `image-loaded` per page — the trigger Etcher's `_onResize`
          // (and our own correctAspect path) relies on to re-sync the
          // overlay viewBox to the real natural dimensions once each
          // image's bitmap arrives. Skipping this step left newly-
          // appended-chapter overlays stuck at 0×0, so addShapes for
          // hydrated annotations landed in a zero-sized box (invisible)
          // and user-drawn shapes on the new chapter never rendered
          // either. Specs must match the shape fresco_strip stores:
          // `{url, width, height}` with the SAME proxied URL the
          // overlay's `getImages()` reads via `img.src`.
          const newSpecs = data.images.map((img) => {
            const rawUrl = (img && img.url) || img;
            return {
              url: SHELL.dataset.proxyUrl + "?" + new URLSearchParams({ url: rawUrl }).toString(),
              width: (img && img.width) || 1000,
              height: (img && img.height) || 1500
            };
          });
          const stripHandle = window.__stripHandle;
          if (stripHandle && typeof stripHandle.appendSources === "function") {
            stripHandle.appendSources(newSpecs);
          }
          // Etcher 0.5.3+ knows how to build overlays for pages added
          // after mount, but the build runs on _onResize / image-loaded
          // — both of which are async w.r.t. the addShapes call below.
          // refreshPages() forces the re-sync synchronously so the new
          // overlays exist before we splice in this chapter's
          // hydrated annotations.
          const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
          if (layer && typeof layer.refreshPages === "function") {
            layer.refreshPages();
          }
          // Splice the new chapter's annotations into the existing
          // layer. The persisted `image_idx` on each shape is the
          // chapter-local index (0..count-1); rebase onto the global
          // strip index by adding the offset of where this chapter
          // starts in the appended container.
          if (Array.isArray(data.etcher_shapes) && data.etcher_shapes.length > 0) {
            if (layer && typeof layer.addShapes === "function") {
              const shifted = data.etcher_shapes.map((s) => {
                const localIdx = typeof s.image_idx === "number" ? s.image_idx : 0;
                return { ...s, image_idx: baseIdxBeforeAppend + localIdx };
              });
              layer.addShapes(shifted);
            }
          }
        } catch (_) {
          // Network error or bad JSON — surface a brief retry hint and
          // leave the divider so a re-scroll re-attempts.
        } finally {
          loadingNextChapter = false;
          hideLoadingDivider();
        }
      }

      // Scan visible imgs and find the dominant one (most viewport
      // overlap). Replaces fresco's `getScrollState()` for our
      // multi-chapter case — fresco only knows the originally-mounted
      // `sources` so anything we've appended post-mount is invisible
      // to it.
      //
      // Uses the cached position snapshot (imgPositionsSorted) instead
      // of a querySelectorAll + offsetTop/offsetHeight walk over every
      // mounted img — this runs on every scroll frame via the progress
      // indicator, and with a few chapters appended the full DOM walk
      // was hundreds of forced-layout reads per frame, i.e. jank on
      // exactly the smooth-scroll the snap motion rides on.
      function chapterForIdx(idx) {
        for (let i = 0; i < loadedChapters.length; i++) {
          const c = loadedChapters[i];
          if (idx >= c.startIdx && idx <= c.endIdx) return c;
        }
        return null;
      }
      function snapshotMultiChapterState() {
        if (!imgPositionsSorted) refreshImgPositions();
        const sorted = imgPositionsSorted;
        if (!sorted || sorted.length === 0) return null;
        const vpTop = container.scrollTop;
        const vpBottom = vpTop + container.clientHeight;
        // Binary search for the first img whose bottom clears the
        // viewport top, then walk only the visible few for max overlap.
        let lo = 0, hi = sorted.length - 1;
        while (lo < hi) {
          const mid = (lo + hi) >>> 1;
          const e = sorted[mid];
          if (vpTop < e.top + e.h) hi = mid; else lo = mid + 1;
        }
        let best = null, bestOverlap = -1;
        for (let i = lo; i < sorted.length; i++) {
          const e = sorted[i];
          if (e.top >= vpBottom) break;
          const overlap = Math.max(0, Math.min(e.top + e.h, vpBottom) - Math.max(e.top, vpTop));
          if (overlap > bestOverlap) { bestOverlap = overlap; best = e; }
        }
        if (!best) return null;
        const meta = chapterForIdx(best.idx);
        if (!meta) return null;
        const localPage = (best.idx - meta.startIdx) + 1;
        const center = (vpTop + vpBottom) / 2;
        const fraction = Math.max(0, Math.min(1, (center - best.top) / Math.max(1, best.h)));
        return { chapter: meta.chapter, page: localPage, totalPages: meta.count, fraction: fraction };
      }

      function flushProgress({ keepalive = false } = {}) {
        if (transientMode) {
          chapterElapsedMs = 0;
          return;
        }
        const st = snapshotMultiChapterState();
        if (!st) return;
        const elapsed = Math.round(chapterElapsedMs / 1000);
        chapterElapsedMs = 0;
        fetch(`${SHELL.dataset.settingsBase}/progress`, {
          method: "PUT",
          headers: {
            "content-type": "application/json",
            "x-csrf-token": SHELL.dataset.csrfToken
          },
          credentials: "same-origin",
          body: JSON.stringify({
            chapter: st.chapter,
            page: st.page,
            page_fraction: st.fraction,
            elapsed,
            total_pages: st.totalPages
          }),
          keepalive
        }).catch(() => {});
      }
      function scheduleProgressSave() {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(flushProgress, PROGRESS_DEBOUNCE_MS);
      }

      // Update the address bar when the dominant chapter changes so
      // refresh / share / bookmark always reflects what's on screen.
      // Sync the chapter label in both nav bars (mobile top + desktop
      // sidebar) to whichever chapter is currently dominant in the
      // viewport. The server-rendered `Ch. {@chapter}` reflects the
      // chapter the user landed on, so as the strip auto-appends
      // chapters we need to keep the visible nav in sync.
      function syncChapterLabel(chapter) {
        const text = "Ch. " + chapter;
        const mLbl = document.getElementById("strip-chapter-label-mobile");
        const dLbl = document.getElementById("strip-chapter-label-desktop");
        if (mLbl && mLbl.textContent !== text) mLbl.textContent = text;
        if (dLbl && dLbl.textContent !== text) dLbl.textContent = text;
      }

      // Retarget the nav's prev/next arrow anchors at the dominant
      // chapter's neighbours — server-rendered hrefs are relative to
      // the chapter the user landed on and go stale as the strip
      // auto-appends chapters. Neighbours come from loadedChapters;
      // for the tail chapter the next name is recovered from its
      // images-API URL (`.../CHAPTER/images`). The initial chapter's
      // server-rendered prev href is already correct and stays.
      function syncChapterNavLinks(chapter) {
        const i = loadedChapters.findIndex((c) => c.chapter === chapter);
        if (i < 0) return;
        const base = SHELL.dataset.settingsBase;
        if (i > 0) {
          const prevUrl = base + "/" + encodeURIComponent(loadedChapters[i - 1].chapter);
          document.querySelectorAll('a[title="Previous chapter"]').forEach((a) => { a.href = prevUrl; });
        }
        let nextUrl = "";
        if (i < loadedChapters.length - 1) {
          nextUrl = base + "/" + encodeURIComponent(loadedChapters[i + 1].chapter);
        } else if (loadedChapters[i].nextChapterApi) {
          const seg = loadedChapters[i].nextChapterApi.split("/").slice(-2)[0];
          if (seg) nextUrl = base + "/" + seg;
        }
        document.querySelectorAll('a[title="Next chapter"]').forEach((a) => {
          if (nextUrl) a.href = nextUrl;
          a.classList.toggle("hidden", !nextUrl);
        });
      }

      function maybeUpdateUrlForDominantChapter() {
        const st = snapshotMultiChapterState();
        if (!st) return;
        syncChapterLabel(st.chapter);
        if (st.chapter !== lastObservedChapter) {
          lastObservedChapter = st.chapter;
          SHELL.dataset.chapter = st.chapter;
          syncChapterNavLinks(st.chapter);
          const newUrl = SHELL.dataset.settingsBase + "/" + encodeURIComponent(st.chapter);
          try { history.replaceState({ chapter: st.chapter }, "", newUrl); } catch (_) {}
        }
      }

      // Fresco's viewport-change event fires when the dominant image
      // crosses, which is the same trigger the bottom indicator
      // already uses successfully — wire the nav-label sync to it
      // too so the label tracks the indicator instead of waiting for
      // the next container scroll event.
      handle.on("viewport-change", () => {
        try {
          const st = snapshotMultiChapterState();
          if (st) syncChapterLabel(st.chapter);
        } catch (_) {}
        markPageTransition();
      });

      // Forward-sliding gutter prewarm used to live here, tied to
      // every `viewport-change`. It hot-cached the next few snap
      // targets so first-tap snap didn't await cold gutter detection
      // — but viewport-change fires many times per snap animation,
      // and each prewarmAhead allocates a Float32Array(h) + a fresh
      // <img> + a stream of ImageData row buffers for any cold idx
      // it touches. After ~5min of continuous reading the GC pressure
      // builds up and snapTo stalls ~half a second per tap. Trade-off
      // reversed: better to take a one-time cold-gutter await on the
      // first snap into a new image than to bleed memory the whole
      // session. The mount-time and chapter-append prewarms (one-shot
      // each) stay — those don't recur.

      // Has the user crossed 2/3 of the LAST loaded chapter (i.e. less
      // than 1/3 of it remains below the viewport)? Chapter-relative
      // so a short epilogue chapter still triggers prefetch at roughly
      // the same reading-progress point a long chapter would.
      function pastTwoThirdsOfLastChapter() {
        const last = loadedChapters[loadedChapters.length - 1];
        if (!imgPositions) refreshImgPositions();
        const first = imgPositions[last.startIdx];
        const end   = imgPositions[last.endIdx];
        if (!first || !end) return false;
        const chapterTop = first.top;
        const chapterBottom = end.top + end.h;
        const chapterHeight = chapterBottom - chapterTop;
        if (chapterHeight <= 0) return false;
        const vpBottom = container.scrollTop + container.clientHeight;
        return vpBottom > chapterTop + chapterHeight * (2 / 3);
      }

      // Memory windowing for appended-chapter imgs. Fresco's built-in
      // windowing covers the originally-mounted sources; we mirror the
      // same eviction strategy for everything we've appended. Keeps
      // 5 viewport heights of imgs decoded on either side of the
      // current view; anything past that has its `src` cleared (the
      // `aspect-ratio` style preserves layout so scroll position
      // doesn't jump) and is restored on scrollback.
      const MEM_WINDOW_VPS = 5;
      let memWindowRaf = null;
      function scheduleMemoryWindow() {
        if (memWindowRaf) return;
        memWindowRaf = requestAnimationFrame(() => {
          memWindowRaf = null;
          applyMemoryWindow();
        });
      }
      function applyMemoryWindow() {
        if (sources.length <= originalChapterCount) return; // nothing appended yet
        const vp = container.clientHeight || window.innerHeight;
        const vpTop = container.scrollTop;
        const vpBottom = vpTop + vp;
        const keep = vp * MEM_WINDOW_VPS;
        // Bounds from the cached position snapshot; only the appended
        // idx range is eligible, so iterate that directly instead of a
        // querySelectorAll + per-img offset reads every scroll frame.
        // Eviction preserves layout (aspect-ratio keeps the height),
        // so the snapshot stays valid across evict/restore.
        if (!imgPositions) refreshImgPositions();
        for (let idx = originalChapterCount; idx < sources.length; idx++) {
          const pos = imgPositions[idx];
          if (!pos) continue;
          const tooFarAbove = pos.top + pos.h < vpTop - keep;
          const tooFarBelow = pos.top > vpBottom + keep;
          const shouldEvict = tooFarAbove || tooFarBelow;
          const img = imgEl(idx);
          if (!img) continue;
          const isEvicted = img.dataset.evicted === "true";
          if (shouldEvict && !isEvicted) {
            img.removeAttribute("src");
            img.dataset.evicted = "true";
          } else if (!shouldEvict && isEvicted) {
            const src = img.getAttribute("data-src");
            if (src) img.src = src;
            delete img.dataset.evicted;
          }
        }
      }

      // Single scroll listener — schedules progress save, swaps the
      // URL on chapter boundary, kicks off the next-chapter fetch
      // once the user has cleared 2/3 of the current chapter, and
      // runs the appended-chapter memory window.
      container.addEventListener("scroll", () => {
        recordActivity();
        // Auto-close the nav as soon as the user starts reading
        // (= scrolling the strip). Cross-chapter clicks via in-nav
        // links use window.location and reload the page; NAV_KEY
        // stays "1" across that reload so the bar reappears on the
        // destination chapter — supports the "rapid chapter-flip"
        // flow without forcing the user to re-open the bar each time.
        if (typeof window.__stripToggleNav === "function" &&
            sessionStorage.getItem(NAV_KEY) === "1") {
          window.__stripSetNav && window.__stripSetNav(false);
        }
        // Movie-player cursor hide on scroll. CSS rule keys off
        // `data-cursor-hidden`. Next mousemove unhides.
        SHELL.dataset.cursorHidden = "true";
        scheduleProgressSave();
        maybeUpdateUrlForDominantChapter();
        scheduleMemoryWindow();
        if (!loadingNextChapter && pastTwoThirdsOfLastChapter()) {
          const last = loadedChapters[loadedChapters.length - 1];
          if (last.nextChapterApi) fetchAndAppendNextChapter();
        }
      }, { passive: true });

      // Other activity signals so a user reading a long panel without
      // physically scrolling (e.g., tap-zooming, keyboard nav, just
      // moving their finger) still counts toward chapter_seconds.
      // All passive — no preventDefault interference with native gestures.
      ["touchstart", "pointerdown", "keydown"].forEach((evt) => {
        container.addEventListener(evt, recordActivity, { passive: true });
      });

      // Flush before the tab closes / page unloads. `keepalive: true`
      // lets the request survive the unload (Chrome/Safari/Firefox).
      window.addEventListener("beforeunload", () => {
        recordActivity();
        flushProgress({ keepalive: true });
      });
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") {
          // Capture the final segment before flushing; tab-hidden gap
          // would otherwise be lost on resume (lastActivityAt resets).
          recordActivity();
          flushProgress({ keepalive: true });
        } else {
          // Tab returned — treat resume as a fresh activity timestamp
          // so the hidden interval doesn't get retroactively credited.
          lastActivityAt = performance.now();
        }
      });

      // ── Resume scroll position ────────────────────────────────────
      // The shell carries data-resume-page (1-based image idx) and
      // data-resume-fraction (0.0–1.0 within that image's height).
      // We can't scroll until the target image has loaded — natural
      // height is unknown otherwise. `maybeResumeScroll` is called
      // from the image-loaded handler; it triggers once when the
      // target idx fires.
      const RESUME_IDX = Math.max(0, (parseInt(SHELL.dataset.resumePage, 10) || 1) - 1);
      const RESUME_FRAC = parseFloat(SHELL.dataset.resumeFraction) || 0;
      // `?ann=` deep-links manage their own scroll target — skip resume
      // so it doesn't race with us and clobber the shape position.
      let resumed = !!ANN_DEEPLINK_UUID || (RESUME_IDX === 0 && RESUME_FRAC === 0);

      // The viewer renders each img with `aspect-ratio: w/h` inline,
      // so `offsetTop` / `offsetHeight` are correct from the moment
      // the DOM mounts — we don't need to wait for pixels to load.
      // (Earlier code required every prior img to be `.complete` for
      // accurate layout, but with lazy-loading + out-of-order loads
      // that window often never opened.)
      function applyResume() {
        if (resumed) return;
        const target = imgEl(RESUME_IDX);
        if (!target || !target.offsetHeight) return;
        resumed = true;
        const y = Math.round(target.offsetTop + RESUME_FRAC * target.offsetHeight);
        container.scrollTop = y;
      }

      function maybeResumeScroll(_loadedIdx) {
        // Kept as the image-loaded hook in case the initial sweep
        // missed (e.g. img hadn't laid out yet). Each load re-tries.
        applyResume();
      }

      // Apply once now (layout is already correct from aspect-ratio CSS).
      // requestAnimationFrame so the scroll happens after the initial
      // paint completes — otherwise some browsers ignore the scrollTop
      // assignment on a freshly-mounted scroll container.
      requestAnimationFrame(applyResume);

      // ── Coord helpers (display-px ↔ source-px) ────────────────────
      // Memoized: imgEl is on several per-frame paths (settle loop,
      // memory window, snap scans) and a container-wide querySelector
      // per call is O(mounted imgs) each time.
      function imgEl(idx) {
        const hit = imgElCache.get(idx);
        if (hit && hit.isConnected) return hit;
        const el = container.querySelector(
          '[data-fresco-strip-img][data-image-idx="' + idx + '"]'
        );
        if (el) imgElCache.set(idx, el);
        return el;
      }
      // Cached image-position snapshot ({top, h} by idx) used by the
      // snap scan loop. scrollPxToImagePos is called ~800×/snap and a
      // naive container.querySelector per call (× sources.length per
      // probe) becomes 100k+ DOM queries once chapters auto-append.
      // The snapshot collapses that to a single querySelectorAll +
      // cheap array lookups. It only holds NUMBERS — not DOM refs —
      // so there's no stale-element risk; it's invalidated whenever
      // image-loaded or chapter-append could shift layout.
      let imgPositions = null;
      // Sibling array of imgPositions sorted by scroll-px top, used for
      // O(log N) lookup in scrollPxToImagePos. The original idx-keyed
      // map is retained because other callers index by idx directly.
      let imgPositionsSorted = null;
      function refreshImgPositions() {
        const out = [];
        const sorted = [];
        const imgs = container.querySelectorAll("[data-fresco-strip-img]");
        for (let i = 0; i < imgs.length; i++) {
          const idx = parseInt(imgs[i].getAttribute("data-image-idx"), 10);
          if (isNaN(idx)) continue;
          const top = imgs[i].offsetTop;
          const h   = imgs[i].offsetHeight;
          out[idx] = { top, h };
          sorted.push({ idx, top, h });
        }
        sorted.sort((a, b) => a.top - b.top);
        imgPositions = out;
        imgPositionsSorted = sorted;
        return out;
      }
      function invalidateImgPositions() {
        imgPositions = null;
        imgPositionsSorted = null;
      }
      function scrollPxToImagePos(scrollPx) {
        if (!imgPositions) refreshImgPositions();
        const sorted = imgPositionsSorted;
        if (!sorted || sorted.length === 0) return { imageIdx: 0, srcY: 0 };
        // Binary search for smallest i with scrollPx < sorted[i].top +
        // sorted[i].h. This loop runs ~500x per snap; converting from
        // linear to binary kept snap latency flat as `sources.length`
        // grew with appended chapters.
        let lo = 0, hi = sorted.length - 1;
        while (lo < hi) {
          const mid = (lo + hi) >>> 1;
          const e = sorted[mid];
          if (scrollPx < e.top + e.h) hi = mid;
          else lo = mid + 1;
        }
        const e = sorted[lo];
        const srcH = sources[e.idx]?.height || 0;
        if (srcH <= 0 || e.h <= 0) return { imageIdx: e.idx, srcY: 0 };
        const srcY = Math.max(0, scrollPx - e.top) * (srcH / e.h);
        return { imageIdx: e.idx, srcY };
      }
      function imagePosToScrollPx(imageIdx, srcY) {
        const el = imgEl(imageIdx);
        if (!el) return null;
        const srcH = sources[imageIdx]?.height || 0;
        if (srcH <= 0) return null;
        return el.offsetTop + (srcY * el.offsetHeight / srcH) - gutterDetectOffset();
      }
      // Snap offset from the top — 10% of viewport height. Snap
      // targets land `offset` px below the top edge so the user sees
      // a strip of the previous panel for context instead of the next
      // panel flush against the top.
      function gutterDetectOffset() {
        return Math.round(container.clientHeight * 0.10);
      }
      function isWhiteAtScroll(scrollPx) {
        scrollPx = scrollPx + gutterDetectOffset();
        const { imageIdx, srcY } = scrollPxToImagePos(scrollPx);
        const cached = gutterCache.get(imageIdx);
        if (!cached) return false;
        const bands = cached.bands || [];
        for (let i = 0; i < bands.length; i++) {
          if (srcY >= bands[i][0] && srcY < bands[i][1]) return true;
        }
        // Band detection ignores the top/bottom MARGIN_PCT of every
        // image, so a gutter that straddles an image boundary — white
        // padding at the bottom of one file plus the top of the next,
        // the NORMAL case when chapters are ripped panel-aligned — is
        // invisible to the band list. The phase walk then sails through
        // the natural stop at the boundary to the next in-image gutter:
        // a full-panel overshoot. Recover it here: inside the margin
        // zones, consult the per-row variance directly and count flat
        // rows as gutter. Art that runs to the image edge keeps high
        // variance and stays non-white, so the original margin
        // rationale (edge artifacts ≠ gutters) is preserved.
        if (cached.rowVar && cached.h) {
          const margin = Math.floor(cached.h * MARGIN_PCT);
          const iy = Math.max(0, Math.min(cached.h - 1, Math.round(srcY)));
          if (iy < margin || iy >= cached.h - margin) {
            return (
              cached.rowVar[iy] <= snapConfig.gutter_tolerance &&
              (cached.bg === undefined ||
                Math.abs(cached.rowMean[iy] - cached.bg) <= 48)
            );
          }
        }
        return false;
      }

      // ── OCR worker (smart auto-reader) ───────────────────────────────
      // Needs `imgEl` + `gutterFor` which live inside `whenReady`, so we
      // close over them here. Outside helpers (module scope) define the
      // cache and worker plumbing.
      async function ocrImageNow(idx) {
        if (ocrCache.has(idx) || ocrInFlight.has(idx)) return;
        const src = sources[idx];
        if (!src || !src.url) return;
        const stored = loadOcrFromStorage(src.url);
        if (stored) {
          ocrCache.set(idx, { panelWordCounts: stored.panelWordCounts });
          trimMapToCap(ocrCache, OCR_CACHE_MAX);
          return;
        }
        const gutters = await gutterFor(idx, sources);
        if (!gutters || !gutters.bands || !gutters.h) return;
        ocrInFlight.add(idx);
        try {
          const w = gutters.w, h = gutters.h;
          // Capture canvas BEFORE awaiting the worker — the live img
          // could be evicted by memory windowing while we wait. If the
          // img is unloaded (no naturalWidth), fall back to re-fetching.
          const live = imgEl(idx);
          let captured = null;
          if (live && live.complete && live.naturalWidth > 0) {
            captured = document.createElement("canvas");
            captured.width = w; captured.height = h;
            try { captured.getContext("2d").drawImage(live, 0, 0); }
            catch (_) { captured = null; }
          }
          if (!captured) {
            const im = await loadImage(src.url);
            if (!im) return;
            captured = document.createElement("canvas");
            captured.width = w; captured.height = h;
            try { captured.getContext("2d").drawImage(im, 0, 0); }
            catch (_) { return; }
          }
          const worker = await getOcrWorker();
          if (!worker) return;
          // Build panel boundaries: 0, …gutter midpoints, h.
          const mids = gutters.bands.map(([a, b]) => Math.floor((a + b) / 2));
          const boundaries = [0, ...mids, h];
          const panelWordCounts = [];
          for (let i = 0; i < boundaries.length - 1; i++) {
            const y0 = boundaries[i], y1 = boundaries[i + 1];
            const panelH = y1 - y0;
            if (panelH < 20) { panelWordCounts.push(0); continue; }
            const pCanvas = document.createElement("canvas");
            const maxW = 800;
            const scale = Math.min(1, maxW / w);
            pCanvas.width  = Math.round(w * scale);
            pCanvas.height = Math.round(panelH * scale);
            const pCtx = pCanvas.getContext("2d");
            pCtx.drawImage(captured, 0, y0, w, panelH, 0, 0, pCanvas.width, pCanvas.height);
            try {
              const { data } = await worker.recognize(pCanvas);
              const words = (data.words || []).filter(wd =>
                wd.confidence > 30 && wd.text.length >= 2 && /[a-zA-Z]{2}/.test(wd.text)
              );
              panelWordCounts.push(words.length);
            } catch (_) {
              panelWordCounts.push(0);
            }
          }
          ocrCache.set(idx, { panelWordCounts });
          trimMapToCap(ocrCache, OCR_CACHE_MAX);
          saveOcrToStorage(src.url, panelWordCounts);
        } catch (e) {
          console.warn("[strip] ocr failed for idx", idx, e);
        } finally {
          ocrInFlight.delete(idx);
        }
      }
      function enqueueOcr(idx) {
        if (ocrCache.has(idx) || ocrInFlight.has(idx)) return;
        ocrSerialChain = ocrSerialChain
          .then(() => ocrImageNow(idx))
          .catch(() => {});
      }

      // Returns current panel info for the probe scroll position, or
      // null if image/gutter data isn't ready. Word count is scaled
      // down for tall panels that span multiple viewports (we only
      // credit the user for the portion they're actually seeing).
      function getCurrentPanelInfo(overrideScrollPx) {
        const probePx = (overrideScrollPx === undefined ? container.scrollTop : overrideScrollPx) + gutterDetectOffset();
        const { imageIdx, srcY } = scrollPxToImagePos(probePx);
        const cached = gutterCache.get(imageIdx);
        if (!cached) return null;
        const bands = cached.bands || [];
        const h = cached.h || sources[imageIdx]?.height || 0;
        if (!h) return null;
        const mids = bands.map(([a, b]) => Math.floor((a + b) / 2));
        let panelIdx = 0;
        for (let i = 0; i < mids.length; i++) {
          if (srcY > mids[i]) panelIdx = i + 1; else break;
        }
        const totalPanels = mids.length + 1;
        const boundaries = [0, ...mids, h];
        const panelH = boundaries[panelIdx + 1] - boundaries[panelIdx];
        const el = imgEl(imageIdx);
        const displayH = el?.offsetHeight || 0;
        const panelDisplayH = displayH > 0 ? (panelH * displayH / h) : 0;
        const vh = container.clientHeight;
        const visibleRatio = (panelDisplayH > vh && vh > 0) ? (vh / panelDisplayH) : 1;
        const ocr = ocrCache.get(imageIdx);
        const totalWords = ocr ? (ocr.panelWordCounts[panelIdx] || 0) : 0;
        const wordCount = Math.round(totalWords * visibleRatio);
        const density = computeDensity(wordCount);
        // Adaptive delay: 2s (no text) → 8s (dense text).
        const delay = 2 + density * 6;
        return { wordCount, density, delay, panelIdx, totalPanels, ocrReady: !!ocr };
      }
      // Live per-row brightness/variance — uses the per-row stats
      // detection already computed (no per-call canvas re-sampling).
      // Returns null when the image isn't analyzed yet or srcY is OOB.
      function pixelStatsAtScroll(scrollPx) {
        scrollPx = scrollPx + gutterDetectOffset();
        const { imageIdx, srcY } = scrollPxToImagePos(scrollPx);
        const cached = gutterCache.get(imageIdx);
        if (!cached || !cached.rowMean) return null;
        const iy = Math.round(srcY);
        if (iy < 0 || iy >= cached.h) return null;
        return { mean: cached.rowMean[iy], variance: cached.rowVar[iy], bg: cached.bg };
      }
      // "Is this still essentially empty space" — looser than the
      // band-detection threshold so phase 2 can keep scanning across
      // borderline rows that didn't qualify as a band (just over
      // variance, or a too-short run). Must also stay near the page
      // background's brightness: flat-but-dark rows on a white page
      // are a blurred panel opening, not empty space, and riding
      // through them is what landed snaps inside the art.
      function isLooseGutterAtScroll(scrollPx) {
        const s = pixelStatsAtScroll(scrollPx);
        if (!s) return false;
        const tol = (snapConfig.gutter_tolerance || 300) * 5;
        if (s.variance > tol) return false;
        return s.bg === undefined || Math.abs(s.mean - s.bg) <= 64;
      }

      // ── Snap target finder (legacy algorithm — see show.html.heex
      // line 753). Only the scroll surface is adapted:
      // container.scrollTop instead of window.scrollY,
      // container.clientHeight instead of window.innerHeight.
      //
      // The landing rule is legacy's: the FIRST non-gutter row after
      // the ridden-through gutter is the target — that's the panel
      // start, and it's what aligns with the debug detection line.
      // `findNextSustainedContent` (land at the first *dense* content
      // instead) deliberately moved the landing off the panel start
      // and is now opt-in via `snapConfig.smart_landing` only.
      const CONTENT_VARIANCE = 600;
      const CONTENT_RUN_LEN  = 16;
      const SCAN_MAX_SRC     = 2000;
      function findNextSustainedContent(scrollY) {
        const { imageIdx, srcY } = scrollPxToImagePos(scrollY + gutterDetectOffset());
        const cached = gutterCache.get(imageIdx);
        if (!cached || !cached.rowVar) return scrollY;
        const rowVar = cached.rowVar;
        const startIy = Math.round(srcY);
        if (startIy < 0 || startIy >= cached.h) return scrollY;
        const endIy = Math.min(cached.h, startIy + SCAN_MAX_SRC);
        let runStart = -1;
        let run = 0;
        for (let iy = startIy; iy < endIy; iy++) {
          if (rowVar[iy] > CONTENT_VARIANCE) {
            if (runStart === -1) runStart = iy;
            run++;
            if (run >= CONTENT_RUN_LEN) {
              const r = imagePosToScrollPx(imageIdx, runStart);
              return (typeof r === "number" && r >= scrollY) ? r : scrollY;
            }
          } else {
            runStart = -1;
            run = 0;
          }
        }
        return scrollY;
      }

      async function findSnapTargetCore(direction, traceMode, startYOverride) {
        const startY    = startYOverride !== undefined ? startYOverride : container.scrollTop;
        const scanStep  = 5;
        const maxTravel = container.clientHeight * snapConfig.scan_distance;
        const debounce  = snapConfig.min_gutter_width || 50;

        // Cold-cache strategy: await detection for EVERY image in the
        // scan range. An un-analyzed image reads as "not a gutter", so
        // the old fire-and-forget warm let the phase walk sail through
        // unknown territory and fall back to a raw 3-viewport jump —
        // the "sometimes it just doesn't snap" failure. The range is
        // ≤ ~4 images at ~10-40ms each, is almost always prewarmed
        // already (image-loaded + the predictive queue's own builds),
        // so this await is a no-op on the hot path and a one-off
        // ~100ms on a truly cold first tap — a snap that lands right
        // beats one that fires instantly into the wrong place.
        const loY = direction > 0 ? startY : Math.max(0, startY - maxTravel);
        const hiY = direction > 0 ? startY + maxTravel : startY;
        const loIdx = scrollPxToImagePos(loY).imageIdx;
        const hiIdx = scrollPxToImagePos(hiY).imageIdx;
        const waits = [];
        for (let i = loIdx; i <= hiIdx; i++) {
          if (i >= 0 && i < sources.length && !gutterCache.has(i)) {
            waits.push(gutterFor(i, sources));
          }
        }
        if (waits.length) await Promise.all(waits);

        // Debounced gutter check: requires `debounce` source-px of
        // continuous white after panel content before counting as gutter.
        function scanIsGutter(y, state) {
          const white = isWhiteAtScroll(y);
          if (!white) { state.lastNonWhite = y; return false; }
          if (Math.abs(y - state.lastNonWhite) < debounce) return false;
          return true;
        }

        const startOnGutter = isWhiteAtScroll(startY);

        if (direction === 1) {
          // Forward: gutter(skip) -> panel -> gutter(ride through) -> panel_start -> stop
          //
          // Phase 0 here is "we're on the starting gutter, keep going
          // until we leave it." Production uses scanIsGutter for the
          // exit test, which has an entry-debounce — at d=0 the debounce
          // returns false even though we're white, so phase 0 instantly
          // transitions to phase 1, collapsing the on-gutter case into
          // the on-panel case. Net effect in the wild: tapping next
          // while sitting on a gutter only nudges you to the immediate
          // next panel start (~50 px) instead of skipping the panel as
          // intended.
          //
          // Fix: phase 0 uses raw isWhiteAtScroll for exit, no debounce.
          // It's correct here because we already know (via startOnGutter)
          // that we're inside the gutter — we just need to wait until
          // the pixels actually become non-white.
          //
          // Phase 2 exit is band-aware: when scanIsGutter goes false,
          // consult the precomputed bands for the current image. If
          // ANOTHER gutter band starts within `bandSkipDistance` source
          // px of where we are, the "non-white" pixel was just noise
          // inside the visual gutter (chat-bubble outline, faint stroke,
          // detection split). Jump past that next band and keep scanning.
          // Only return when there's no nearby band — that's a real
          // panel start.
          // Noise-skip radius, sharply reduced from the old 2000: a
          // 2000-source-px window could classify an entire small or
          // pale panel between two gutters as "noise" and skip it —
          // the main overshoot source vs the legacy reader, which
          // stopped at ANY sustained non-white. 300px only bridges
          // gaps on the scale of a real gutter's internal noise.
          // Content decisions use the shared gapHasRealContent
          // predicate (dark rows OR sustained variance), so pale art
          // counts as content here exactly like it does in band
          // merging.
          const bandSkipDistance = snapConfig.gutter_skip_noise ?? 300;
          // Walk forward through bands in the same image, chaining any
          // bands whose gaps contain no real content. Returns the
          // scroll y at the end of the last chained band, or null.
          function findGutterChainEnd(scrollY) {
            const { imageIdx, srcY } = scrollPxToImagePos(scrollY + gutterDetectOffset());
            const cached = gutterCache.get(imageIdx);
            if (!cached || !cached.bands || !cached.bands.length) return null;
            const bands = cached.bands;
            const rowMean = cached.rowMean;
            const rowVar  = cached.rowVar;
            let curIdx = -1;
            for (let i = 0; i < bands.length; i++) {
              if (srcY >= bands[i][0] && srcY < bands[i][1]) { curIdx = i; break; }
              if (srcY < bands[i][0]) { curIdx = i; break; }
            }
            if (curIdx < 0) return null;
            const trace = traceMode ? [] : null;
            let endIy = bands[curIdx][1];
            if (trace) trace.push({ step: "start", imageIdx, srcY: Math.round(srcY), curIdx, endIy, bandsLen: bands.length, startBand: bands[curIdx] });
            for (let i = curIdx + 1; i < bands.length; i++) {
              const gap = bands[i][0] - endIy;
              if (gap > bandSkipDistance) {
                if (trace) trace.push({ step: "break-gap-too-large", i, gap, bandSkipDistance });
                break;
              }
              const hasContent = gapHasRealContent(rowMean, rowVar, endIy, bands[i][0], snapConfig.gutter_tolerance);
              if (trace) {
                // Sample some rows to show in the trace
                const samples = [];
                const sampleStep = Math.max(1, Math.floor(gap / 20));
                let contentCount = 0;
                for (let iy = endIy; iy < bands[i][0]; iy += sampleStep) {
                  if (rowMean[iy] < GAP_CONTENT_MEAN) contentCount++;
                  samples.push({ iy, m: Math.round(rowMean[iy]), v: Math.round(rowVar[iy]) });
                }
                trace.push({ step: "gap-check", i, fromIy: endIy, toIy: bands[i][0], gap, hasContent, nextBand: bands[i], samples });
              }
              if (hasContent) break;
              endIy = bands[i][1];
            }
            const r = imagePosToScrollPx(imageIdx, endIy);
            if (trace) {
              trace.push({ step: "result", endIy, scrollY: r });
              console.log("[snap-trace] " + JSON.stringify({ scrollY: Math.round(scrollY), result: Math.round(r), trace }, null, 2));
            }
            return (typeof r === "number") ? r : null;
          }
          // phase=1 always (matches production). Production's phase-0
          // path collapses to phase 1 at d=0 because scanIsGutter's
          // entry-debounce returns false at zero distance — net effect
          // is that snapping from inside a gutter lets phase 1 immediately
          // see the gutter we're sitting in, hits phase 2 after the
          // debounce, then exits at this gutter's END = the next panel
          // start (= what the user wants).
          //
          // The earlier phase-0 fix (use raw isWhiteAtScroll for exit)
          // was misguided: it landed at the band end then transitioned
          // to phase 1, which scanned through the panel to the NEXT
          // gutter, overshooting the target by one full panel.
          let phase = 1;
          const state = { lastNonWhite: startY };
          let d = 0;
          while (d < maxTravel) {
            const y = startY + d;
            const onGutter = scanIsGutter(y, state);
            if (phase === 1 && onGutter) {
              phase = 2;
              // Chain short-circuit DISABLED — was over-extending past
              // genuine panels in some cases and breaking the half-step
              // distance calculation in long panels. Per-pixel phase 2
              // below handles the noise-skip via band lookup + loose-
              // gutter check, which is what was working before.
              //
              // Diagnostic trace kept (snap-debug logs the chain decision
              // even though we don't use the result).
              if (traceMode) findGutterChainEnd(y);
            }
            if (phase === 2 && !onGutter) {
              const { imageIdx, srcY } = scrollPxToImagePos(y + gutterDetectOffset());
              const cached = gutterCache.get(imageIdx);
              let skipped = false;
              if (cached) {
                const bands = cached.bands || [];
                let nextBand = null;
                for (const b of bands) {
                  if (b[0] > srcY) { nextBand = b; break; }
                }
                if (nextBand && (nextBand[0] - srcY) <= bandSkipDistance) {
                  // Content-aware skip: if the rows between srcY and
                  // nextBand.start carry no real content (dark rows OR
                  // sustained variance — the shared predicate, so pale
                  // art counts), the gap is noise inside what is
                  // visually one gutter → skip past nextBand and
                  // resume. Any real content → return y so the snap
                  // lands at it, exactly like legacy stopped at any
                  // sustained non-white.
                  const startIy = Math.max(0, Math.round(srcY));
                  const endIy   = Math.min(cached.h, nextBand[0]);
                  const hasContent = gapHasRealContent(
                    cached.rowMean, cached.rowVar, startIy, endIy, snapConfig.gutter_tolerance
                  );
                  if (!hasContent) {
                    const skipTo = imagePosToScrollPx(imageIdx, nextBand[1]);
                    if (typeof skipTo === "number" && skipTo > y) {
                      d = (skipTo - startY) + scanStep;
                      state.lastNonWhite = skipTo;
                      skipped = true;
                    }
                  }
                }
              }
              if (skipped) continue;
              // No nearby band (or gap has real content) — final
              // safety net: the absolute-brightness loose check still
              // catches obviously-white rows the band detector skipped.
              if (isLooseGutterAtScroll(y)) {
                d += scanStep;
                continue;
              }
              return y;
            }
            d += scanStep;
          }
        } else {
          if (startOnGutter) {
            // Backward from gutter: find panel start just below (scan forward to exit gutter)
            for (let d = 0; d < maxTravel; d += scanStep) {
              if (!isWhiteAtScroll(startY + d)) return startY + d;
            }
          } else {
            // Backward from panel: go up to previous panel's top
            // panel -> gutter(ride through) -> prev panel -> gutter -> stop at prev panel top
            let phase = 1;
            let lastPanelY = startY;
            const state = { lastNonWhite: startY };
            for (let d = 0; d < maxTravel; d += scanStep) {
              const y = startY - d;
              const onGutter = scanIsGutter(y, state);
              if (phase === 1 && onGutter)  phase = 2;
              if (phase === 2 && !onGutter) { phase = 3; lastPanelY = y; }
              if (phase === 3 && !onGutter) lastPanelY = y;
              if (phase === 3 && onGutter)  return lastPanelY;
            }
          }
        }
        return startY + direction * maxTravel;
      }

      async function findSnapTarget(direction, traceMode, startYOverride) {
        const raw = await findSnapTargetCore(direction, traceMode, startYOverride);
        // Legacy landing rule: the first non-gutter row IS the target —
        // it's what lines up with the debug detection line. The
        // "sustained content" adjustment (land at the first *dense*
        // region instead) moved landings into the panel on soft/pale
        // openings; opt back in per-manga via snapConfig.smart_landing.
        if (direction > 0 && snapConfig.smart_landing) {
          const adjusted = findNextSustainedContent(raw);
          if (traceMode) {
            console.log("[snap-trace] raw=" + Math.round(raw) + " adjusted=" + Math.round(adjusted) + " scrollTop=" + Math.round(container.scrollTop));
          }
          return adjusted;
        }
        return raw;
      }

      // ── Predictive snap queue ─────────────────────────────────────
      // Precomputes the next N forward snap targets from the current
      // resting position, chaining findSnapTargetCore from each target
      // to the next — so a tap consumes a ready-made target with zero
      // scan latency, and the detection awaits inside the build double
      // as prewarm for the next ~N panels' images.
      //
      // Targets are stored as layout-independent anchors (imageIdx +
      // source row) and resolved to pixels at consume time, so aspect
      // corrections / dims updates / chapter appends shift them
      // correctly instead of invalidating them. The queue only fully
      // flushes on config changes (different knobs = different
      // targets). A generation token aborts superseded builds.
      const SNAP_QUEUE_DEPTH = 7;
      let snapQueue = [];
      let snapQueueGen = 0;

      function queueAnchorFromPx(px) {
        const pos = scrollPxToImagePos(px + gutterDetectOffset());
        return { imageIdx: pos.imageIdx, srcY: pos.srcY };
      }
      function queueAnchorToPx(a) {
        return imagePosToScrollPx(a.imageIdx, a.srcY);
      }
      async function rebuildSnapQueue() {
        if (!panelSnapEnabled) { snapQueue = []; return; }
        const gen = ++snapQueueGen;
        const fresh = [];
        let fromY = container.scrollTop;
        for (let n = 0; n < SNAP_QUEUE_DEPTH; n++) {
          let t = await findSnapTargetCore(1, false, fromY);
          // Same optional adjustment the live path applies, so queued
          // and live targets can never disagree.
          if (snapConfig.smart_landing) t = findNextSustainedContent(t);
          if (gen !== snapQueueGen) return; // superseded by a newer build
          if (!(t > fromY + 1)) break;      // end of strip / no progress
          fresh.push(queueAnchorFromPx(t));
          fromY = t;
        }
        if (gen === snapQueueGen) snapQueue = fresh;
      }
      // First queue entry still ahead of the current position (passed
      // entries are dropped). Returns a resolved pixel or null.
      function peekQueuedTarget() {
        const cur = container.scrollTop;
        while (snapQueue.length) {
          const px = queueAnchorToPx(snapQueue[0]);
          if (px == null) { snapQueue.shift(); continue; }
          if (px > cur + 4) return px;
          snapQueue.shift();
        }
        return null;
      }
      function flushSnapQueue() {
        snapQueueGen++;
        snapQueue = [];
      }
      let queueRebuildTimer = null;
      function scheduleQueueRebuild(delay) {
        clearTimeout(queueRebuildTimer);
        queueRebuildTimer = setTimeout(() => { rebuildSnapQueue(); }, delay ?? 200);
      }
      // Keep the queue anchored to wherever the user settles — free
      // scrolling shifts which targets are "next". Programmatic snap
      // motion is excluded (snapTo rebuilds explicitly on settle).
      container.addEventListener("scroll", () => {
        if (!snapMotionActive && !snapping) scheduleQueueRebuild(300);
      }, { passive: true });
      // Initial build once layout has settled after mount/resume.
      scheduleQueueRebuild(600);

      // ── Find the next gutter starting from a known panel-start ────
      // findSnapTarget returns the y where a new panel BEGINS (i.e.,
      // the exit of the next gutter). This helper continues scanning
      // forward to find the next gutter ENTRY — together with the panel
      // start, that gives us the panel's length. Used by snapTo's
      // long-panel detector so the "is this a long panel?" decision is
      // based on actual content length, not jump distance. The old
      // distance-based heuristic conflated "user is far from any
      // gutter" with "user is heading into a tall panel" — those are
      // not the same when small panels stack with thin gutters.
      async function findPanelEnd(fromY, direction) {
        const maxTravel = container.clientHeight * snapConfig.scan_distance;
        const loY = direction > 0 ? fromY : fromY - maxTravel;
        const hiY = direction > 0 ? fromY + maxTravel : fromY;
        const loIdx = scrollPxToImagePos(loY).imageIdx;
        const hiIdx = scrollPxToImagePos(hiY).imageIdx;
        // Don't await cold gutters — findPanelEnd's only output is the
        // "panel length" feeding the long-panel half-step heuristic.
        // Unknown panel length → assume short, snap straight to target,
        // user's next tap picks up the half-step once detection has
        // landed. Kicking off detection without await means the scan
        // window is hot by the next tap with zero latency added now.
        for (let i = loIdx; i <= hiIdx; i++) {
          if (i >= 0 && i < sources.length && !gutterCache.has(i)) {
            gutterFor(i, sources);
          }
        }
        // The idx the panel-end question is "about" — if we have no
        // gutter data for it, short-circuit with `fromY` (panelLen = 0,
        // treated as short).
        const fromIdx = scrollPxToImagePos(fromY).imageIdx;
        if (!gutterCache.has(fromIdx)) return fromY;

        const scanStep = 5;
        const debounce = snapConfig.min_gutter_width || 50;
        const state = { lastNonWhite: fromY };
        // Step in by one scan unit so we don't immediately re-detect
        // the gutter that ended the panel we're measuring (fromY is
        // a panel-start, right after a gutter).
        for (let d = scanStep; d < maxTravel; d += scanStep) {
          const y = fromY + direction * d;
          const white = isWhiteAtScroll(y);
          if (!white) { state.lastNonWhite = y; continue; }
          if (Math.abs(y - state.lastNonWhite) < debounce) continue;
          return y;
        }
        return fromY + direction * maxTravel;
      }

      // Shared long-panel adjustment. Given a raw findSnapTarget result,
      // returns where the snap will *actually* land — used by both the
      // snap action and the debug overlay so the two never diverge.
      //
      // Tuned 2026-05-22 from verdict logs (/tmp/fresco_debug.log) +
      // live debug overlay feedback:
      //   - Threshold lowered 1.3·vh → 1.1·vh: borderline panels
      //     (~1100px at vh≈937) had been rated `bad` because they fell
      //     just under the long flag.
      //   - When close to the next panel boundary (absDist ≤ stepSize),
      //     always land AT target — visual feedback confirmed users want
      //     clean snap to the panel start (chat bubble top, panel edge,
      //     etc.) rather than overshooting partway into a long next
      //     panel. Subsequent taps handle long-panel reading via the
      //     half-step branch once absDist > stepSize.
      async function resolveScrollTarget(direction, start, target) {
        const vh = container.clientHeight;
        const absDist = Math.abs(target - start);
        const panelEnd = await findPanelEnd(target, direction);
        const panelLen = Math.abs(panelEnd - target);
        const longThreshold = vh * 1.1;
        const curLong  = snapConfig.long_panel_steps && absDist  >= longThreshold;
        const nextLong = snapConfig.long_panel_steps && panelLen >= longThreshold;
        // Only curLong triggers half-step. nextLong is redundant: once
        // we land at the long panel's start, the next tap's absDist
        // spans the long panel and curLong fires for the half-step.
        // Keeping nextLong here caused snap to mid-step into the gutter
        // when entering a long panel from a short distance.
        const isLongPan = curLong;
        const stepSize = vh * 0.5;
        let scrollTarget = target;
        if (isLongPan && absDist > stepSize) {
          // Inside a long current panel (or far enough that a half-step
          // doesn't overshoot target) — half-step through it. The
          // close-to-target case (absDist ≤ stepSize) always falls
          // through to `target` so the snap lands cleanly at the panel
          // boundary the user can see.
          scrollTarget = start + direction * stepSize;
        }
        return { scrollTarget, panelEnd, panelLen, isLongPan, curLong, nextLong };
      }

      // ── Snap action (verbatim port of production's smartScroll,
      // see show.html.heex line 805). Container.scrollTo instead of
      // window.scrollTo. No top-offset post-processing — matches
      // production exactly.
      let snapping = false;
      // Latest tap that arrived while a snap was in flight — replayed
      // on settle so rapid-tapping doesn't drop inputs (the old fixed
      // 400ms unlock let mid-flight taps through, which computed their
      // target from a mid-animation scrollTop — one of the "lands in
      // the wrong place" sources).
      //
      // Only calls that arrive >QUEUE_MIN_MS into the motion count as
      // a deliberate second tap. Same-gesture bursts land within a few
      // ms of the first call and must keep the old drop semantics:
      // the pointer-lock mouse gesture fires __stripSnap in a while
      // loop (one flick = 2-3 synchronous calls) and keyboard auto-
      // repeat fires every ~33ms — both previously swallowed by the
      // `snapping` guard, and queueing them produced a phantom second
      // snap after the first one landed.
      let queuedSnapDir = 0;
      let snapStartedAt = 0;
      const QUEUE_MIN_MS = 100;
      // True while a programmatic snap motion (animation + settle
      // verification) is in flight. The auto-reader's pause-on-scroll
      // handler checks this so our own scroll animation and correction
      // nudges don't read as user input and self-pause the timer.
      let snapMotionActive = false;

      // ── Settle-verified snap motion ───────────────────────────────
      // The old motion was fire-and-forget: compute an absolute pixel,
      // scrollTo(smooth), hope the browser lands there. Two things
      // break that in a lazy-loaded strip:
      //
      //   1. Layout shift mid-animation. correctAspect (image-loaded)
      //      rewrites an <img>'s aspect-ratio when its real dims arrive
      //      — placeholder 1000×1500 vs a real 800×8000 manhwa strip
      //      shifts everything below by thousands of px. The smooth
      //      scroll keeps animating toward the STALE pixel, so the snap
      //      visibly overshoots/undershoots the gutter even though the
      //      debug lines (recomputed per frame from fresh layout) show
      //      the correct target. Scrolling toward new territory is
      //      exactly what triggers the lazy loads, so this fires at the
      //      worst possible moment.
      //   2. Browsers cancel smooth scrollTo on user gestures and can
      //      stop short on heavy main-thread frames — silently.
      //
      // Fix: express the target as a layout-independent ANCHOR
      // (imageIdx + fraction into that image's height — source-space,
      // so it survives any reflow) and monitor the animation with a
      // rAF loop:
      //   - if the anchor's pixel drifts from the issued target mid-
      //     flight (layout shift), re-issue scrollTo at the fresh px;
      //   - once scrolling goes still, verify the landing and apply a
      //     final instant correction when off by more than a few px;
      //   - abort immediately on any user gesture (touch/wheel/
      //     pointer/key) — never fight the user for scroll position.
      function captureAnchor(targetPx) {
        const pos = scrollPxToImagePos(targetPx + gutterDetectOffset());
        const el = imgEl(pos.imageIdx);
        if (!el || !el.offsetHeight) return null;
        const frac = (targetPx + gutterDetectOffset() - el.offsetTop) / el.offsetHeight;
        // frac can poke past 1 when the target px maps beyond the last
        // image — clamp loosely so the anchor still tracks that image.
        // The element ref is carried in the anchor so the settle loop
        // reads offsets directly instead of a DOM lookup per frame.
        return { el, imageIdx: pos.imageIdx, frac: Math.max(0, Math.min(1.2, frac)) };
      }
      function anchorToPx(anchor) {
        if (!anchor) return null;
        const el = anchor.el;
        if (!el.isConnected || !el.offsetHeight) return null;
        return el.offsetTop + anchor.frac * el.offsetHeight - gutterDetectOffset();
      }
      const SNAP_RETARGET_EPS  = 8;    // px of anchor drift before re-issuing scrollTo
      const SNAP_CORRECT_EPS   = 4;    // px of landing error before final correction
      const SNAP_SETTLE_FRAMES = 3;    // consecutive still frames near target = settled
      const SNAP_STALL_FRAMES  = 12;   // still-but-off-target frames = browser stopped short
      const SNAP_TIMEOUT_MS    = 4000;
      function performSnapMotion(initialTarget, behavior, withAnchor) {
        const anchor = withAnchor ? captureAnchor(initialTarget) : null;
        const stats = { retargets: 0, corrections: 0, interrupted: false, settleMs: 0, issuedTarget: Math.round(initialTarget) };
        let interrupted = false;
        const onIntent = () => { interrupted = true; };
        const intentTargets = [
          [container, "touchstart"], [container, "wheel"],
          [container, "pointerdown"], [window, "keydown"]
        ];
        intentTargets.forEach(([t, ev]) => t.addEventListener(ev, onIntent, { passive: true, capture: true }));
        snapMotionActive = true;
        let issued = initialTarget;
        function issue(top, b) {
          // Clamp to the scrollable range so "issued" is a pixel the
          // container can actually reach — otherwise the settle check
          // never sees us "near target" at the strip's very bottom.
          top = Math.max(0, Math.min(top, container.scrollHeight - container.clientHeight));
          issued = top;
          if (b === "auto") container.scrollTop = top;
          else container.scrollTo({ top, behavior: "smooth" });
        }
        issue(initialTarget, behavior);
        const t0 = performance.now();
        let lastTop = container.scrollTop;
        let stable = 0;
        return new Promise((resolve) => {
          function done() {
            stats.settleMs = Math.round(performance.now() - t0);
            stats.interrupted = interrupted;
            intentTargets.forEach(([t, ev]) => t.removeEventListener(ev, onIntent, { capture: true }));
            snapMotionActive = false;
            resolve(stats);
          }
          function frame() {
            if (interrupted) return done();
            if (performance.now() - t0 > SNAP_TIMEOUT_MS) return done();
            const cur = container.scrollTop;
            const px = anchorToPx(anchor);
            if (px != null && Math.abs(px - issued) > SNAP_RETARGET_EPS) {
              // Layout shifted under the animation — chase the anchor.
              stats.retargets++;
              if (snapDebugOn) console.log("[snap-trace] retarget " + Math.round(issued) + " -> " + Math.round(px));
              issue(px, behavior);
              stable = 0; lastTop = container.scrollTop;
              return requestAnimationFrame(frame);
            }
            if (Math.abs(cur - lastTop) < 1) stable++;
            else { stable = 0; lastTop = cur; }
            const nearIssued = Math.abs(cur - issued) <= SNAP_CORRECT_EPS;
            if (stable >= SNAP_SETTLE_FRAMES && (nearIssued || stable >= SNAP_STALL_FRAMES)) {
              // Landed (or the browser gave up short). Verify against
              // the anchor one last time — layout can shift after the
              // animation stops too (a decode finishing right at the
              // end). Small instant nudge, imperceptible at ≤ a few px
              // of error but exactly what saves the multi-hundred-px
              // misses.
              const fpx = anchorToPx(anchor);
              if (fpx != null && Math.abs(cur - fpx) > SNAP_CORRECT_EPS && stats.corrections < 3) {
                stats.corrections++;
                if (snapDebugOn) console.log("[snap-trace] settle-correct " + Math.round(cur) + " -> " + Math.round(fpx));
                issue(fpx, "auto");
                stable = 0; lastTop = container.scrollTop;
                return requestAnimationFrame(frame);
              }
              return done();
            }
            requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
        });
      }

      async function snapTo(direction) {
        if (snapping) {
          if (performance.now() - snapStartedAt > QUEUE_MIN_MS) queuedSnapDir = direction;
          return;
        }
        snapping = true;
        snapStartedAt = performance.now();
        const vh = container.clientHeight;
        const debugCtx = snapDebugOn ? { startedAt: performance.now() } : null;
        try {
          if (!panelSnapEnabled) {
            // Panel snap off — match production's "scroll by 80% viewport"
            // fallback used when smartScrollEnabled is false. Multiplied
            // by the user's scroll-speed setting (turtle / rabbit).
            const behavior = snapConfig.jump_style === "instant" ? "auto" : "smooth";
            const startNoSnap = container.scrollTop;
            const deltaNoSnap = direction * vh * 0.8 * currentSpeedMultiplier();
            if (debugCtx) {
              debugCtx.mode = "no_snap";
              debugCtx.direction = direction;
              debugCtx.scrollBefore = startNoSnap;
              debugCtx.target = startNoSnap + deltaNoSnap;
            }
            // No anchor — plain viewport-relative move, but still wait
            // for the scroll to settle so `snapping` gates re-entrancy
            // for the whole motion and the verdict bar reads the real
            // landing position.
            await performSnapMotion(startNoSnap + deltaNoSnap, behavior, false);
            return;
          }
          // Fast path: consume a precomputed target from the
          // predictive queue (forward snaps only; debug mode always
          // computes live so traces reflect the real algorithm walk).
          const queuedPx = (direction > 0 && !snapDebugOn) ? peekQueuedTarget() : null;
          const target = queuedPx != null
            ? queuedPx
            : await findSnapTarget(direction, snapDebugOn);
          const start  = container.scrollTop;

          // Long-panel detector — fires the half-step path when either:
          //
          //   (a) the user is currently inside a tall panel (the jump
          //       distance to the next gutter exit exceeds 1.3·vh), or
          //   (b) the user is about to land in a tall panel (the panel
          //       starting at `target` extends >1.3·vh past it).
          //
          // (a) catches "I'm halfway through a long panel; tap should
          // keep reading, not blast to the next panel's start." (b)
          // catches "I'm just past a gutter and the next panel is huge;
          // full-snap would land me at the top of the long panel and
          // make the next tap blast through the bottom." Either signal
          // alone misses cases — the old code used only (a), and my
          // earlier fix briefly used only (b). Together they cover both
          // scenarios without firing on the small close-band moves
          // (where absDist and panelLen are both small).
          const { scrollTarget, panelEnd, panelLen, isLongPan, curLong, nextLong } =
            await resolveScrollTarget(direction, start, target);

          // Consume the queue head only when we're actually landing at
          // it — a long-panel half-step leaves the target ahead, so the
          // next tap re-uses the same precomputed entry.
          if (queuedPx != null && scrollTarget === queuedPx) snapQueue.shift();

          if (debugCtx) {
            debugCtx.mode = "snap";
            debugCtx.direction = direction;
            debugCtx.scrollBefore = start;
            debugCtx.snapFindTarget = target;
            debugCtx.target = scrollTarget;
            debugCtx.isLongPan = isLongPan;
            debugCtx.curLong = curLong;
            debugCtx.nextLong = nextLong;
            debugCtx.panelLen = panelLen;
            debugCtx.panelEnd = panelEnd;
          }

          const behavior = snapConfig.jump_style === "instant" ? "auto" : "smooth";
          if (snapDebugOn) {
            console.log("[snap-trace] snapTo start=" + Math.round(start) +
              " target=" + Math.round(target) +
              " scrollTarget=" + Math.round(scrollTarget) +
              " isLongPan=" + isLongPan +
              " absDist=" + Math.round(Math.abs(target - start)) +
              " behavior=" + behavior);
          }
          const settle = await performSnapMotion(scrollTarget, behavior, true);
          if (debugCtx) debugCtx.settle = settle;
          if (snapDebugOn) {
            console.log("[snap-trace] settled scrollTop=" + Math.round(container.scrollTop) +
              " after " + settle.settleMs + "ms" +
              " retargets=" + settle.retargets +
              " corrections=" + settle.corrections +
              (settle.interrupted ? " (interrupted by user)" : ""));
          }

          // Warm the gutter for the idx the user is about to land in
          // plus one more in the direction of travel. Once per snap,
          // not per viewport-change — bounded allocation. The await
          // chain inside findSnapTarget for the NEXT tap then hits a
          // hot cache and returns instantly, so the next tap snaps
          // without a stall even when the panels are tall and
          // image-loaded fired too late to prescan in time.
          try {
            const landingIdx = scrollPxToImagePos(scrollTarget).imageIdx;
            const step = direction > 0 ? 1 : -1;
            for (let k = 0; k <= 2; k++) {
              const i = landingIdx + step * k;
              if (i >= 0 && i < sources.length) gutterFor(i, sources);
            }
          } catch (_) {}
        } finally {
          // performSnapMotion already awaited real settle (or user
          // interruption) — no fixed-delay guess needed. Verdict bar
          // therefore reads the true landing position instead of a
          // 400ms-in snapshot of a still-moving scroll.
          snapping = false;
          if (debugCtx) showVerdictBar(debugCtx);
          // Top the predictive queue back up from the landing position
          // (short delay so a queued replay tap goes first).
          scheduleQueueRebuild(80);
          const q = queuedSnapDir;
          queuedSnapDir = 0;
          if (q) snapTo(q);
        }
      }

      // ── Snap debugger ─────────────────────────────────────────────
      // Captures landing context + waits for user verdict. Bar auto-
      // dismisses after 8s if the user takes no action (treated as
      // "no opinion", no log). Buttons fire postVerdict and hide.
      const verdictBar  = document.getElementById("strip-snap-verdict-bar");
      const verdictGood = document.getElementById("strip-snap-verdict-good");
      const verdictBad  = document.getElementById("strip-snap-verdict-bad");
      const verdictSkip = document.getElementById("strip-snap-verdict-skip");
      let pendingVerdict = null;
      let verdictTimer  = null;

      function bandsForImage(idx) {
        const c = gutterCache.get(idx);
        return c ? (c.bands || []) : null;
      }
      function rawBandsForImage(idx) {
        const c = gutterCache.get(idx);
        return c ? (c.rawBands || c.bands || []) : null;
      }
      // Distance from `srcY` to the nearest band edge (in source px) —
      // negative when inside a band, positive when outside, null when
      // bands aren't loaded yet for that image.
      function nearestBandEdge(idx, srcY) {
        const bands = bandsForImage(idx);
        if (!bands || bands.length === 0) return null;
        let best = Infinity;
        let inside = false;
        for (const b of bands) {
          if (srcY >= b[0] && srcY < b[1]) {
            inside = true;
            best = Math.min(best, srcY - b[0], b[1] - srcY);
          } else {
            best = Math.min(best, Math.abs(srcY - b[0]), Math.abs(srcY - b[1]));
          }
        }
        return inside ? -best : best;
      }

      function showVerdictBar(ctx) {
        if (!verdictBar) return;
        const offset = gutterDetectOffset();
        const probeY = container.scrollTop + offset;
        const pos = scrollPxToImagePos(probeY);
        const img = sources[pos.imageIdx] || {};
        const bands = bandsForImage(pos.imageIdx);
        const onBand = isWhiteAtScroll(container.scrollTop);
        pendingVerdict = {
          ...ctx,
          scrollAfter: container.scrollTop,
          gutterOffsetPx: offset,
          landing: {
            imageIdx:  pos.imageIdx,
            imageUrl:  img.url || null,
            imageW:    img.width || null,
            imageH:    img.height || null,
            srcY:      pos.srcY,
            onBand:    onBand,
            nearestBandEdgeSrcPx: nearestBandEdge(pos.imageIdx, pos.srcY),
            bands:     bands ? bands.slice(0, 20) : null,
            rawBands:  rawBandsForImage(pos.imageIdx)?.slice(0, 20) ?? null
          }
        };
        verdictBar.classList.remove("hidden");
        if (verdictTimer) clearTimeout(verdictTimer);
        verdictTimer = setTimeout(() => hideVerdictBar(false), 8000);
      }
      function hideVerdictBar(_logged) {
        if (verdictTimer) { clearTimeout(verdictTimer); verdictTimer = null; }
        if (verdictBar) verdictBar.classList.add("hidden");
        pendingVerdict = null;
      }
      function postVerdict(verdict) {
        if (!pendingVerdict) return;
        const elapsedMs = Math.round(performance.now() - pendingVerdict.startedAt);
        const payload = {
          event: "snap_verdict",
          verdict: verdict,
          elapsedMs: elapsedMs,
          ts: Date.now(),
          source: SHELL.dataset.source,
          slug: SHELL.dataset.slug,
          chapter: SHELL.dataset.chapter,
          ua: navigator.userAgent,
          viewportH: container.clientHeight,
          viewportW: container.clientWidth,
          panelSnapEnabled,
          snapConfig: { ...snapConfig },
          snap: {
            mode: pendingVerdict.mode,
            direction: pendingVerdict.direction,
            scrollBefore: pendingVerdict.scrollBefore,
            snapFindTarget: pendingVerdict.snapFindTarget,
            target: pendingVerdict.target,
            scrollAfter: pendingVerdict.scrollAfter,
            isLongPan: pendingVerdict.isLongPan || false,
            panelLen: pendingVerdict.panelLen ?? null,
            panelEnd: pendingVerdict.panelEnd ?? null,
            gutterOffsetPx: pendingVerdict.gutterOffsetPx,
            settle: pendingVerdict.settle ?? null
          },
          landing: pendingVerdict.landing
        };
        hideVerdictBar(true);
        // Browser pipeline plug `protect_from_forgery` requires the
        // CSRF token; `accepts: ["html"]` blocks an explicit
        // `accept: application/json`, so we omit Accept and let the
        // browser default kick in.
        fetch(SHELL.dataset.debugLogUrl, {
          method: "POST",
          headers: {
            "content-type": "application/json",
            "x-csrf-token": SHELL.dataset.csrfToken || ""
          },
          body: JSON.stringify(payload),
          credentials: "same-origin"
        }).catch(() => {});
      }
      verdictGood?.addEventListener("click", () => postVerdict("good"));
      verdictBad?.addEventListener("click",  () => postVerdict("bad"));
      verdictSkip?.addEventListener("click", () => hideVerdictBar(false));

      // ── Snap debug overlay ────────────────────────────────────────
      // Three horizontal lines:
      //   - probe (yellow, fixed):   at gutterDetectOffset() from the top
      //     of the viewport — where the snap probe actually samples pixels.
      //   - next  (green, absolute): where findSnapTarget(1) would land.
      //   - prev  (red, absolute):   where findSnapTarget(-1) would land.
      // The next/prev lines live inside the container so they scroll with
      // content. Their positions refresh on scroll-end (debounced) so we
      // don't fire findSnapTarget per frame — the function awaits gutter
      // loads and we don't want overlapping calls.
      const probeLine = document.createElement("div");
      probeLine.id = "strip-debug-probe-line";
      probeLine.innerHTML = '<span class="strip-debug-label">probe</span>';
      probeLine.style.display = "none";
      document.body.appendChild(probeLine);

      function makeTargetLine(id, kind) {
        const el = document.createElement("div");
        el.id = id;
        el.innerHTML = '<span class="strip-debug-label">' + kind + '</span>';
        el.style.display = "none";
        container.appendChild(el);
        return el;
      }
      const nextLine = makeTargetLine("strip-debug-next-line", "next");
      const prevLine = makeTargetLine("strip-debug-prev-line", "prev");

      // Position the fixed probe line to overlay the strip container at
      // gutterDetectOffset() from its top edge. Recomputed on resize so
      // we follow viewport rotation/chrome show-hide on mobile.
      function positionProbeLine() {
        if (probeLine.style.display === "none") return;
        const rect = container.getBoundingClientRect();
        probeLine.style.top = (rect.top + gutterDetectOffset()) + "px";
      }

      function setLineFor(el, label, scrollY, panelLen, isLongPan) {
        const cTop = container.scrollTop;
        const cH   = container.clientHeight;
        // Hide when out of the current scroll window (line would be
        // off-screen anyway; absolute positioning would still render it
        // but we'd waste a paint).
        if (scrollY < cTop - cH || scrollY > cTop + cH * 2) {
          el.style.display = "none";
          return;
        }
        el.style.display = "";
        el.style.top = scrollY + "px";
        const lbl = el.querySelector(".strip-debug-label");
        if (lbl) {
          const pos = scrollPxToImagePos(scrollY + gutterDetectOffset());
          let text = label + "  y=" + Math.round(scrollY) +
            "  img=" + pos.imageIdx + "  srcY=" + Math.round(pos.srcY);
          if (typeof panelLen === "number") {
            const longFlag = isLongPan ? " ⟂LONG·½" : "";
            text += "  panel=" + Math.round(panelLen) + "px" + longFlag;
          }
          lbl.textContent = text;
        }
      }

      // Debounced refresher. Generation counter guards against stale
      // findSnapTarget resolutions clobbering newer ones (user scrolls
      // fast, two refreshes are in flight, the second resolves first).
      let debugGen = 0;
      async function refreshTargetLines() {
        if (!snapDebugOn) return;
        if (!panelSnapEnabled) {
          // Without panel snap, "next/prev" is just startY ± 0.8*vh.
          const vh = container.clientHeight;
          const startY = container.scrollTop;
          setLineFor(nextLine, "next", startY + 0.8 * vh);
          setLineFor(prevLine, "prev", startY - 0.8 * vh);
          return;
        }
        const gen = ++debugGen;
        const start = container.scrollTop;
        const [nextY, prevY] = await Promise.all([
          findSnapTarget(1),
          findSnapTarget(-1)
        ]);
        if (gen !== debugGen) return;
        // Apply the same long-panel half-step adjustment snapTo will
        // use, so the debug lines mark where the snap *actually* lands,
        // not just the raw findSnapTarget output.
        const [nextR, prevR] = await Promise.all([
          resolveScrollTarget(1, start, nextY),
          resolveScrollTarget(-1, start, prevY)
        ]);
        if (gen !== debugGen) return;
        setLineFor(nextLine, "next", nextR.scrollTarget, nextR.panelLen, nextR.isLongPan);
        setLineFor(prevLine, "prev", prevR.scrollTarget, prevR.panelLen, prevR.isLongPan);
      }
      // rAF-coalesced — one refresh per frame, always using current
      // scrollTop. Old code debounced 250ms which made the line stale
      // (`snapTo` would read fresh scrollTop and land somewhere the
      // line hadn't caught up to yet).
      let debugRafScheduled = false;
      function scheduleRefreshTargets() {
        if (!snapDebugOn) return;
        if (debugRafScheduled) return;
        debugRafScheduled = true;
        requestAnimationFrame(() => {
          debugRafScheduled = false;
          refreshTargetLines();
        });
      }
      container.addEventListener("scroll", scheduleRefreshTargets, { passive: true });
      window.addEventListener("resize", () => {
        positionProbeLine();
        if (typeof positionProbeLabel === "function") positionProbeLabel();
        scheduleRefreshTargets();
      });

      // Snap-debug probe-line label: shows the GUTTER / no-gutter
      // hit-test at the probe Y, the tolerance, and the auto-reader
      // timer state. Mirrors the legacy reader's debug HUD content
      // (minus OCR-driven word/density figures — those need the
      // TesseractJs preload which is deferred).
      //
      // Separate fixed element (not a child of the 2px probe line)
      // so it renders reliably regardless of probe-line clipping;
      // matches the legacy reader's pattern in show.html.heex.
      const probeLabelEl = document.createElement("div");
      probeLabelEl.id = "strip-debug-probe-label";
      probeLabelEl.style.cssText =
        "position:fixed;left:8px;z-index:36;pointer-events:none;" +
        "background:rgba(0,0,0,0.75);color:#fff;padding:3px 8px;" +
        "border-radius:4px;font:12px ui-monospace,SFMono-Regular,Menlo,monospace;" +
        "white-space:nowrap;display:none;";
      document.body.appendChild(probeLabelEl);
      let probeLabelRaf = null;
      function arProbeText() {
        let base;
        if (!arEnabled) {
          base = "AR off · " + arDelaySeconds + "s delay";
        } else if (arPausedRemaining > 0) {
          base = "AR paused · resume in " + (arPausedRemaining / 1000).toFixed(1) + "s · " + arDelaySeconds + "s delay";
        } else if (arNextJumpAt > 0) {
          const remaining = Math.max(0, (arNextJumpAt - Date.now()) / 1000);
          base = "AR on · jump " + remaining.toFixed(1) + "s · " + arDelaySeconds + "s delay";
        } else if (arScrolling) {
          base = "AR on · scrolling · " + arDelaySeconds + "s delay";
        } else {
          base = "AR on · " + arDelaySeconds + "s delay";
        }
        if (arSmart) {
          try {
            const info = getCurrentPanelInfo();
            if (info) {
              base += "  |  words " + info.wordCount
                   + " · density " + Math.round(info.density * 100) + "%"
                   + " · panel " + (info.panelIdx + 1) + "/" + info.totalPanels
                   + (info.ocrReady ? " · smart " + info.delay.toFixed(1) + "s" : " (ocr pending)");
            } else {
              base += "  |  panel info pending";
            }
          } catch (_) {}
        }
        return base;
      }
      function gutterProbeText() {
        const sy = container.scrollTop;
        const tol = snapConfig.gutter_tolerance;
        const hit = isWhiteAtScroll(sy);
        return (hit ? "GUTTER ✓" : "no gutter") + "  (tol " + tol + ")";
      }
      function positionProbeLabel() {
        const rect = container.getBoundingClientRect();
        probeLabelEl.style.top = (rect.top + gutterDetectOffset() + 6) + "px";
      }
      function updateProbeLabel() {
        try {
          probeLabelEl.textContent = gutterProbeText() + "  |  " + arProbeText();
          probeLine.style.background = isWhiteAtScroll(container.scrollTop)
            ? "rgba(34, 197, 94, 0.9)"     // lime
            : "rgba(239, 68, 68, 0.9)";    // red
        } catch (_) {}
      }
      function startProbeLabelLoop() {
        if (probeLabelRaf != null) return;
        const tick = () => {
          if (probeLabelEl.style.display === "none") { probeLabelRaf = null; return; }
          updateProbeLabel();
          probeLabelRaf = requestAnimationFrame(tick);
        };
        probeLabelRaf = requestAnimationFrame(tick);
      }
      function stopProbeLabelLoop() {
        if (probeLabelRaf != null) {
          cancelAnimationFrame(probeLabelRaf);
          probeLabelRaf = null;
        }
      }
      function setSnapDebugOverlay(on) {
        if (on) {
          probeLine.style.display = "";
          probeLabelEl.style.display = "";
          positionProbeLine();
          positionProbeLabel();
          updateProbeLabel();
          startProbeLabelLoop();
          // Kick a refresh so the next/prev lines render immediately
          // instead of waiting for the user's first scroll.
          refreshTargetLines();
        } else {
          probeLine.style.display = "none";
          probeLabelEl.style.display = "none";
          nextLine.style.display = "none";
          prevLine.style.display = "none";
          stopProbeLabelLoop();
        }
      }
      // Apply current toggle state on mount.
      setSnapDebugOverlay(snapDebugOn);
      // Expose so the settings-toggle change handler can drive it.
      window.__stripSetSnapDebugOverlay = setSnapDebugOverlay;

      function performAction(action) {
        if (action === "next") snapTo(1);
        else if (action === "prev") snapTo(-1);
        else if (action === "menu") window.__stripToggleNav?.();
      }

      window.__stripHandle = handle;
      window.__stripSnap   = snapTo;
      // Predictive-queue controls for the (module-scope) snap-config
      // handlers: a config change means different targets, so flush
      // and rebuild from the current position.
      window.__stripFlushSnapQueue   = flushSnapQueue;
      window.__stripRebuildSnapQueue = () => scheduleQueueRebuild(50);
      // Read accessors for the desktop pointer-lock gesture handler —
      // it lives outside this closure and needs the current snap-mode
      // flag plus the user's scroll-speed multiplier (turtle / rabbit).
      window.__stripIsSnapEnabled  = () => panelSnapEnabled;
      window.__stripSpeedMultiplier = currentSpeedMultiplier;
      // Lets the pointer-lock gesture handler discard flick movement
      // while a snap motion is in flight — a physical flick streams
      // mousemove events for hundreds of ms, long past the same-gesture
      // window the snapTo queue can filter on its own.
      window.__stripIsSnapping = () => snapping;

      // ── Auto reader ───────────────────────────────────────────────
      // Timer-driven snap-to-next-panel. Settings: on/off + delay
      // (1-20s per panel). Persisted per slug. Pauses on any user
      // interaction (scroll, touch, key) so the user can intervene
      // without the timer fighting their input; floating Resume
      // button picks up where the pause left off.
      //
      // State is declared OUTSIDE the try/catch so the snap-debug
      // probe-label loop further down can read arEnabled / timing
      // for the debug HUD without scope issues.
      const AR_DELAY_KEY = "fresco-strip-test:auto-reader-delay:" + SLUG;
      const AR_SMART_KEY = "fresco-strip-test:auto-reader-smart:" + SLUG;
      const AR_TICK_LEAD_MS = 700;
      let arEnabled = false;
      let arTimer = null;
      let arScrolling = false;
      let arDelaySeconds = (() => {
        const raw = parseInt(localStorage.getItem(AR_DELAY_KEY) || "5", 10);
        return (isNaN(raw) || raw < 1 || raw > 20) ? 5 : raw;
      })();
      let arNextJumpAt = 0;
      let arPausedRemaining = 0;
      let arSmart = localStorage.getItem(AR_SMART_KEY) === "true";
      // Adaptive delay used by both arTick / arStart. Smart mode reads
      // OCR-derived `info.delay`; non-smart returns the slider value.
      function arDelayMs() {
        if (arSmart) {
          const info = getCurrentPanelInfo();
          if (info && info.ocrReady) return Math.max(1000, Math.round(info.delay * 1000));
        }
        return arDelaySeconds * 1000;
      }
      try {
        const arToggle = document.getElementById("strip-auto-reader-toggle");
        const arDelaySlider = document.getElementById("strip-auto-reader-delay");
        const arDelayLabel = document.getElementById("strip-auto-reader-delay-label");
        const arResumeBtn = document.getElementById("strip-auto-reader-resume");

        function arTick() {
          arScrolling = true;
          arNextJumpAt = 0;
          snapTo(1);
          setTimeout(() => {
            arScrolling = false;
            if (!arEnabled) return;
            const ms = arDelayMs();
            arNextJumpAt = Date.now() + ms;
            arTimer = setTimeout(arTick, ms);
          }, AR_TICK_LEAD_MS);
        }
        function arStart() {
          arStop();
          if (arResumeBtn) arResumeBtn.classList.add("hidden");
          if (!arEnabled) return;
          const ms = arDelayMs();
          arNextJumpAt = Date.now() + ms;
          arTimer = setTimeout(arTick, ms);
        }
        function arStop() {
          if (arTimer) { clearTimeout(arTimer); arTimer = null; }
          arNextJumpAt = 0;
          arPausedRemaining = 0;
          if (arResumeBtn) arResumeBtn.classList.add("hidden");
        }
        function arPause() {
          if (!arEnabled || !arTimer) return;
          arPausedRemaining = Math.max(0, arNextJumpAt - Date.now());
          arNextJumpAt = 0;
          clearTimeout(arTimer);
          arTimer = null;
          if (arResumeBtn) arResumeBtn.classList.remove("hidden");
        }
        function arResume() {
          if (!arEnabled) return;
          if (arResumeBtn) arResumeBtn.classList.add("hidden");
          const wait = arPausedRemaining > 0 ? arPausedRemaining : arDelaySeconds * 1000;
          arPausedRemaining = 0;
          arNextJumpAt = Date.now() + wait;
          arTimer = setTimeout(arTick, wait);
        }
        if (arDelaySlider) arDelaySlider.value = String(arDelaySeconds);
        if (arDelayLabel)  arDelayLabel.textContent = arDelaySeconds + "s";
        arDelaySlider?.addEventListener("input", () => {
          const v = parseInt(arDelaySlider.value, 10);
          if (isNaN(v)) return;
          arDelaySeconds = Math.max(1, Math.min(20, v));
          if (arDelayLabel) arDelayLabel.textContent = arDelaySeconds + "s";
          localStorage.setItem(AR_DELAY_KEY, String(arDelaySeconds));
          if (arEnabled) arStart();
        });
        arToggle?.addEventListener("change", () => {
          arEnabled = !!arToggle.checked;
          if (arEnabled) arStart();
          else arStop();
        });
        function arOnUserInteraction(e) {
          if (arScrolling) return;
          // Scroll events fired by our own snap animation / settle
          // corrections are programmatic — only pause on scrolls the
          // user actually caused. (Long smooth snaps outlive the
          // arScrolling window of AR_TICK_LEAD_MS, which used to make
          // the auto-reader pause itself mid-jump.) Touch/key still
          // pause even during a snap — that IS user intent.
          if (e.type === "scroll" && snapMotionActive) return;
          if (e instanceof KeyboardEvent && e.key === "Enter") return;
          if (arEnabled && arTimer) arPause();
        }
        container.addEventListener("scroll",     arOnUserInteraction, { passive: true });
        container.addEventListener("touchstart", arOnUserInteraction, { passive: true });
        window.addEventListener("keydown",       arOnUserInteraction, { passive: true });
        arResumeBtn?.addEventListener("click", () => {
          if (arPausedRemaining > 0) arResume();
          else arStart();
        });
        window.addEventListener("beforeunload", arStop);

        // Smart toggle — wires OCR. Flipping on eagerly loads the worker
        // and queues OCR for every loaded image. New images get OCR'd
        // automatically via the image-loaded hook below.
        const arSmartToggle = document.getElementById("strip-auto-reader-smart-toggle");
        if (arSmartToggle) {
          arSmartToggle.checked = arSmart;
          arSmartToggle.addEventListener("change", () => {
            arSmart = arSmartToggle.checked;
            localStorage.setItem(AR_SMART_KEY, arSmart ? "true" : "false");
            if (arSmart) {
              getOcrWorker(); // eagerly load WASM + trained data
              for (let i = 0; i < sources.length; i++) {
                const el = imgEl(i);
                if (el && el.complete && el.naturalWidth > 0) enqueueOcr(i);
              }
            }
          });
          // If smart was on from a prior visit, kick off OCR now for
          // anything already loaded by this point in init.
          if (arSmart) {
            getOcrWorker();
            for (let i = 0; i < sources.length; i++) {
              const el = imgEl(i);
              if (el && el.complete && el.naturalWidth > 0) enqueueOcr(i);
            }
          }
        }
        handle.on("image-loaded", (e) => {
          if (arSmart) enqueueOcr(e.imageIdx);
        });
      } catch (e) {
        console.error("[strip] auto-reader init failed", e);
      }

      // Mouse-wheel speed multiplier — applies in both snap-on and snap-off
      // modes. We swallow the native deltaY and re-scroll with the
      // user's multiplier applied. Only kicks in when multiplier ≠ 1.
      container.addEventListener("wheel", (e) => {
        const mult = currentSpeedMultiplier();
        if (mult === 1) return;
        e.preventDefault();
        const dx = (e.deltaMode === 1 ? e.deltaX * 16 : e.deltaX) * mult;
        const dy = (e.deltaMode === 1 ? e.deltaY * 16 : e.deltaY) * mult;
        container.scrollBy({ top: dy, left: dx, behavior: "auto" });
      }, { passive: false });
      window.__stripAction = performAction;

      // ── Page padding apply ────────────────────────────────────────
      // Production preserves scroll position via elementFromPoint at
      // viewport center, captures top-rect-y, applies the width change,
      // then scrolls by the delta to keep the same image anchored on
      // screen. Same pattern here, scoped to the strip container.
      function applyPadding(pct) {
        pct = Math.max(0, Math.min(90, Math.round(pct)));
        const rect = container.getBoundingClientRect();
        const cx = rect.left + rect.width  / 2;
        const cy = rect.top  + rect.height / 2;
        const centerEl = document.elementFromPoint(cx, cy);
        const anchor = centerEl?.closest("[data-fresco-strip-img]");
        const anchorTop = anchor?.getBoundingClientRect().top;

        currentPadding = pct;
        // Pad the scroll container itself — imgs are width:100% so they
        // reflow to the narrower content-box width. Padding belongs to
        // the scroll surface, so tap zones still cover the side bands.
        container.style.paddingLeft  = (pct / 2) + "vw";
        container.style.paddingRight = (pct / 2) + "vw";
        localStorage.setItem(PADDING_KEY, String(pct));
        const lbl = document.getElementById("strip-page-padding-label");
        if (lbl) lbl.textContent = pct + "%";
        const slider = document.getElementById("strip-page-padding-slider");
        if (slider) slider.value = String(pct);

        if (anchor && anchorTop != null) {
          container.scrollTop += anchor.getBoundingClientRect().top - anchorTop;
        }
        // Tell etcher to re-apply its overlay layout — imgs just
        // reflowed to a new content-box width, so per-image offsets
        // changed and etcher needs to re-read fresco's getImages().
        window.dispatchEvent(new Event("resize"));
      }
      window.__stripApplyPadding = applyPadding;
      // Apply the persisted value on mount.
      applyPadding(currentPadding);

      // ── Tap zones — driven by the user's chosen preset ────────────
      // Matches production: leftThird, rightThird, midTop, midBottom
      // are each assigned an action ("next" | "prev" | "menu") by the
      // preset. Click only fires on non-scroll taps so native scroll
      // is unaffected.
      container.addEventListener("click", (e) => {
        // Annotate mode owns the pointer — don't fire tap zones while
        // user is drawing or clicking on an annotation overlay.
        if (SHELL.dataset.annotateMode === "true") return;
        if (e.target?.closest?.(".strip-annot-box")) return;
        // Clicks on etcher's toolbar (close X, color picker, undo, etc.)
        // shouldn't trigger snap — etcher closes its toolbar by flipping
        // annotateMode off BEFORE the click bubbles, so the data-attr
        // check above misses it.
        if (e.target?.closest?.(".etcher-toolbar")) return;
        if (e.target?.closest?.(".etcher-tooltip")) return;
        // Etcher shapes have `pointer-events: none` so we can't see
        // them via `e.target` or `elementsFromPoint`. We listen on
        // the container directly (not fresco's tap bus, so the
        // data-fresco-suppress-tap mechanism doesn't fire), so we
        // defer to etcher 0.5.1's `layer.shapeAt({imageIdx, x, y})`
        // hit-test — strip geometry is in source-pixel space, mapped
        // from the screen point via the image's natural-vs-rendered
        // ratio.
        const tapImg = e.target?.closest?.('[data-fresco-strip-img]');
        if (tapImg) {
          const tapImageIdx = parseInt(tapImg.dataset.imageIdx, 10);
          if (isFinite(tapImageIdx)) {
            const imgRect = tapImg.getBoundingClientRect();
            const srcW = sources[tapImageIdx]?.width  || tapImg.naturalWidth  || imgRect.width;
            const srcH = sources[tapImageIdx]?.height || tapImg.naturalHeight || imgRect.height;
            const srcX = (e.clientX - imgRect.left) * (srcW / imgRect.width);
            const srcY = (e.clientY - imgRect.top)  * (srcH / imgRect.height);
            const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
            if (layer?.shapeAt?.({ imageIdx: tapImageIdx, x: srcX, y: srcY })) {
              return;
            }
          }
        }
        const preset = TAP_ZONE_PRESETS[tapPreset] || TAP_ZONE_PRESETS.default;
        const rect = container.getBoundingClientRect();
        const xIn = e.clientX - rect.left;
        const yIn = e.clientY - rect.top;
        const w = rect.width, h = rect.height;
        const third = w / 3;
        let zone;
        if (xIn < third) zone = "leftThird";
        else if (xIn > w - third) zone = "rightThird";
        else zone = yIn < h / 2 ? "midTop" : "midBottom";
        performAction(preset[zone]);
      });

      // ── Annotate mode (delegates to Etcher's toolbar) ─────────────
      // The pencil buttons open Etcher's bottom toolbar via the layer
      // API; Etcher handles drawing, color picking, undo/redo, etc.
      // Persistence requires a LiveView ancestor for the `etcher:annotations-changed`
      // event — currently TODO (this page is still a controller page).
      function openEtcherToolbar() {
        const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
        if (!layer) {
          console.warn("[strip] Etcher layer not ready");
          return;
        }
        layer.toggleMode();
      }
      document.getElementById("strip-annotate-toggle-mobile")?.addEventListener("click", openEtcherToolbar);
      document.getElementById("strip-annotate-toggle-desktop")?.addEventListener("click", openEtcherToolbar);
      // Reflect mode state on the shell so our CSS can highlight the
      // active pencil buttons. Etcher emits a CustomEvent on the layer
      // host whenever mode flips.
      document.getElementById("etcher-layer-fresco-strip-reader")?.addEventListener("etcher:mode-changed", (e) => {
        SHELL.dataset.annotateMode = e.detail?.annotationMode ? "true" : "false";
      });

      // ── Etcher shape-drawn composer (strip) ──────────────────────
      // EtcherHostLive pushes `etcher:open-composer` after every
      // shape commit. Same composer markup + flow as the paged
      // reader; just rebound to the strip fresco_id.
      const composer = document.getElementById("etcher-composer");
      const composerContent = document.getElementById("etcher-composer-content");
      const composerPrivate = document.getElementById("etcher-composer-private");
      const composerPost = document.getElementById("etcher-composer-post");
      const composerCancel = document.getElementById("etcher-composer-cancel");
      const composerError = document.getElementById("etcher-composer-error");
      const composerGifBtn = document.getElementById("etcher-composer-gif-btn");
      const composerGifPicker = document.getElementById("etcher-composer-gif-picker");
      const composerGifPreview = document.getElementById("etcher-composer-gif-preview");
      const composerGifRemove = document.getElementById("etcher-composer-gif-remove");
      let composerSelectedGif = null;
      let composerGifLoaded = false;

      function composerSetGif(gif) {
        composerSelectedGif = gif;
        if (!composerGifPreview) return;
        const img = composerGifPreview.querySelector("img");
        if (gif) {
          composerGifPreview.classList.remove("hidden");
          if (img) img.src = gif.preview_url || gif.url;
        } else {
          composerGifPreview.classList.add("hidden");
          if (img) img.src = "";
        }
      }

      function composerLoadGifPicker() {
        if (!composerGifPicker || composerGifLoaded) return;
        composerGifLoaded = true;
        composerGifPicker.innerHTML = `
          <div class="flex gap-1 mb-1">
            <input type="text" class="input input-bordered input-xs flex-1 text-xs" placeholder="Search GIFs..." />
            <button type="button" class="btn btn-xs btn-ghost" data-gif-search>🔍</button>
          </div>
          <div data-gif-results class="grid grid-cols-2 gap-1 max-h-48 overflow-y-auto" style="overscroll-behavior:contain;touch-action:pan-y;"></div>
          <div class="text-[10px] text-base-content/40 text-right mt-1">Powered by GIPHY</div>
        `;
        const input = composerGifPicker.querySelector("input");
        const results = composerGifPicker.querySelector("[data-gif-results]");
        const searchBtn = composerGifPicker.querySelector("[data-gif-search]");
        let searchTimer = null;

        async function doSearch() {
          const q = input.value.trim();
          const gifBase = SHELL.dataset.gifBase;
          if (!gifBase) {
            results.innerHTML = '<div class="p-2 text-xs text-base-content/40 col-span-2">GIFs unavailable</div>';
            return;
          }
          const url = q
            ? `${gifBase}/search?q=${encodeURIComponent(q)}&limit=20`
            : `${gifBase}/trending?limit=20`;
          results.innerHTML = '<div class="text-center p-2"><span class="loading loading-spinner loading-sm"></span></div>';
          try {
            const r = await fetch(url, { credentials: "same-origin" });
            const data = await r.json();
            results.innerHTML = "";
            (data.data || []).forEach((g) => {
              const im = document.createElement("img");
              im.src = g.preview_url;
              im.alt = g.title || "";
              im.className = "w-full rounded cursor-pointer object-cover aspect-square";
              im.addEventListener("click", () => {
                composerSetGif(g);
                composerGifPicker.classList.add("hidden");
              });
              results.appendChild(im);
            });
            if ((data.data || []).length === 0) {
              results.innerHTML = '<div class="text-center p-2 text-xs text-base-content/40 col-span-2">No GIFs found</div>';
            }
          } catch (_) {
            results.innerHTML = '<div class="p-2 text-xs text-error col-span-2">Failed to load GIFs</div>';
          }
        }

        input.addEventListener("input", () => { clearTimeout(searchTimer); searchTimer = setTimeout(doSearch, 400); });
        input.addEventListener("keydown", (e) => { if (e.key === "Enter") { e.preventDefault(); doSearch(); } });
        searchBtn.addEventListener("click", doSearch);
        doSearch();
        input.focus();
      }

      composerGifBtn?.addEventListener("click", () => {
        if (composerGifPicker.classList.contains("hidden")) {
          composerGifPicker.classList.remove("hidden");
          composerLoadGifPicker();
        } else {
          composerGifPicker.classList.add("hidden");
        }
      });
      composerGifRemove?.addEventListener("click", () => composerSetGif(null));

      window.addEventListener("phx:etcher:open-composer", (e) => {
        const uuid = e.detail?.uuid;
        if (!uuid || !composer) return;
        composer.dataset.shapeUuid = uuid;
        composerContent.value = "";
        composerPrivate.checked = false;
        composerSetGif(null);
        composerError.classList.add("hidden");
        composer.showModal();
        setTimeout(() => composerContent.focus(), 100);
      });

      composerCancel?.addEventListener("click", () => composer.close());

      composerPost?.addEventListener("click", async () => {
        const uuid = composer.dataset.shapeUuid;
        const content = composerContent.value.trim();
        const gif = composerSelectedGif;
        if (!uuid || (!content && !gif)) {
          composerContent.focus();
          return;
        }
        composerPost.disabled = true;
        composerError.classList.add("hidden");
        try {
          const body = {
            content: content || "",
            visibility: composerPrivate.checked ? "private" : "public"
          };
          if (gif) body.gif_url = gif.downsized_url || gif.original_url || gif.url;
          const res = await fetch(
            `${SHELL.dataset.apiBase}/${encodeURIComponent(SHELL.dataset.chapter)}/marks/etcher-shapes/${uuid}/comment`,
            {
              method: "POST",
              headers: {
                "content-type": "application/json",
                "x-csrf-token": SHELL.dataset.csrfToken
              },
              credentials: "same-origin",
              body: JSON.stringify(body)
            }
          );
          if (!res.ok) throw new Error(`status ${res.status}`);
          const data = await res.json();
          const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
          if (layer?.patchShape) {
            layer.patchShape(uuid, { metadata: data.tooltip_metadata || { comment_uuid: data.comment_uuid } });
          }
          composer.close();
          if (data.resource_uuid && window.openCommentModal) {
            setTimeout(() => {
              window.openCommentModal(SHELL.dataset.chapter, "1", data.resource_uuid);
            }, 200);
          }
        } catch (err) {
          console.error("[strip etcher composer] failed", err);
          composerError.textContent = "Failed to post comment. Try again.";
          composerError.classList.remove("hidden");
        } finally {
          composerPost.disabled = false;
        }
      });

      // Click an existing etcher shape → open the comment thread.
      // Etcher 0.4.1 fires `etcher:tooltip-pin` on the layer host
      // when the user taps a shape outside annotation mode (strip
      // and canvas modes use the same global pointer listeners).
      const etcherLayerHost = document.getElementById("etcher-layer-fresco-strip-reader");
      etcherLayerHost?.addEventListener("etcher:tooltip-pin", (e) => {
        const uuid = e.detail?.uuid;
        if (!uuid) return;
        const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
        const shape = layer?.getShape?.(uuid);
        const rid = shape?.metadata?.resource_uuid;
        if (rid && window.openCommentModal) {
          window.openCommentModal(SHELL.dataset.chapter, "1", rid);
        }
      });

      // ── EtcherHostLive → patchShape ──────────────────────────────
      // When a fresh-shape's first comment lands via the
      // CommentsComponent modal, EtcherHostLive pushes
      // `etcher:patch-shape` with the rebuilt tooltip metadata so the
      // hover bubble + tooltip-pin click work without a refresh.
      window.addEventListener("phx:etcher:patch-shape", (e) => {
        const { shape_uuid, tooltip_metadata } = e.detail || {};
        if (!shape_uuid) return;
        const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
        if (layer?.patchShape) {
          layer.patchShape(shape_uuid, { metadata: tooltip_metadata || {} });
        }
      });


      // ── Deep-link ?ann=<etcher_shape_uuid> ───────────────────────
      // /comments links a comment back to its shape via ?ann=. Since
      // etcher 0.5.0, `revealShape` polls for late-mounted shapes,
      // scrolls, and pulses in one Promise. We still have to wait for
      // the etcher layer itself to mount — `layerFor` returns null
      // until the LiveView lifecycle wires it up.
      if (ANN_DEEPLINK_UUID) {
        const startedAt = Date.now();
        const waitForLayer = () => {
          const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
          if (!layer || typeof layer.revealShape !== "function") {
            if (Date.now() - startedAt < 10000) setTimeout(waitForLayer, 150);
            return;
          }
          layer.revealShape(ANN_DEEPLINK_UUID, { pulse: true })
            .then(() => {
              const rid = layer.getShape(ANN_DEEPLINK_UUID)?.metadata?.resource_uuid;
              if (rid && window.openCommentModal) {
                setTimeout(() => {
                  window.openCommentModal(SHELL.dataset.chapter, "1", rid);
                }, 1500);
              }
            })
            .catch((err) => console.warn("[strip] ann deep-link", err));
        };
        waitForLayer();
      }

      // ── Keyboard ──────────────────────────────────────────────────
      document.addEventListener("keydown", (e) => {
        const t = e.target;
        if (t && (t.tagName === "TEXTAREA" || t.isContentEditable)) return;
        if (t && t.tagName === "INPUT") {
          // Same guard as the paged reader: focus gets stuck on the
          // settings toggles (checkbox inputs) after closing the nav,
          // which used to silently kill keyboard nav. Only text-like
          // inputs swallow everything; non-text controls keep Space +
          // arrows for their native behavior and pass letters through.
          const type = (t.type || "").toLowerCase();
          const textLike = !["checkbox", "radio", "range", "button", "submit", "file", "color"].includes(type);
          if (textLike) return;
          if (e.key === " " || e.key.startsWith("Arrow")) return;
        }
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        if (e.key === "ArrowDown" || e.key === "j" || e.key === " ") {
          e.preventDefault();
          snapTo(1);
        } else if (e.key === "ArrowUp" || e.key === "k") {
          e.preventDefault();
          snapTo(-1);
        } else if (pendingVerdict && (e.key === "g" || e.key === "G")) {
          e.preventDefault();
          postVerdict("good");
        } else if (pendingVerdict && (e.key === "b" || e.key === "B")) {
          e.preventDefault();
          postVerdict("bad");
        }
      });
    });

    // ============================================================
    // Nav show/hide — production parity: defaults to HIDDEN, swap
    // `hidden` ↔ `flex lg:hidden` (mobile) and `hidden` ↔ `lg:flex`
    // (desktop) on the standard `reader-nav-mobile` / `reader-nav-desktop`
    // class targets. State persists in sessionStorage.
    // ============================================================
    let navVisible = sessionStorage.getItem(NAV_KEY) === "1";
    function setNav(visible) {
      navVisible = visible;
      sessionStorage.setItem(NAV_KEY, visible ? "1" : "0");
      document.querySelectorAll(".reader-nav-desktop").forEach((el) => {
        el.classList.toggle("lg:flex", navVisible);
      });
      document.querySelectorAll(".reader-nav-mobile").forEach((el) => {
        el.classList.toggle("hidden",    !navVisible);
        el.classList.toggle("flex",       navVisible);
        el.classList.toggle("lg:hidden",  navVisible);
      });
    }
    function toggleNav() { setNav(!navVisible); }
    if (navVisible) setNav(true);
    window.__stripToggleNav = toggleNav;
    // Exposed for the scroll-handler auto-close path (scrolling the
    // strip = "user is reading" = close the bar). Scroll handler
    // lives in a different IIFE so it talks to setNav via window.
    window.__stripSetNav = setNav;

    // Cursor unhide on mousemove — companion to the scroll-handler's
    // `SHELL.dataset.cursorHidden = "true"`. Single listener at
    // window level catches mousemove anywhere over the reader.
    window.addEventListener("mousemove", () => {
      const sh = document.getElementById("fresco-strip-shell");
      if (sh && sh.dataset.cursorHidden === "true") sh.dataset.cursorHidden = "false";
    }, { passive: true });

    // ============================================================
    // Settings modal — open button, all settings controls. All state
    // mirrors production's scrollConfig shape so the controls feel
    // identical even though storage is strip-test-scoped.
    // ============================================================
    const modal = document.getElementById("strip-settings-modal");

    function syncSettingsUI() {
      // Panel snap toggle
      const snapToggle = document.getElementById("strip-panel-snap-toggle");
      if (snapToggle) snapToggle.checked = panelSnapEnabled;
      const cvToggle = document.getElementById("strip-comments-visible");
      if (cvToggle) cvToggle.checked = commentsVisible;
      // Snap tuning section visibility (matches production — hidden
      // when panel snap is off).
      const cfgSection = document.getElementById("strip-snap-config-section");
      if (cfgSection) cfgSection.style.display = panelSnapEnabled ? "" : "none";

      // Jump style buttons
      document.querySelectorAll(".strip-snap-jump-btn").forEach((btn) => {
        const on = btn.dataset.value === snapConfig.jump_style;
        btn.classList.toggle("btn-primary", on);
        btn.classList.toggle("btn-ghost",  !on);
      });
      // Scan distance
      const scan = document.getElementById("strip-snap-scan-distance");
      if (scan) scan.value = String(snapConfig.scan_distance);
      // Long panel steps
      const lps = document.getElementById("strip-snap-long-panel-steps");
      if (lps) lps.checked = !!snapConfig.long_panel_steps;
      // Gutter tolerance
      const tol = document.getElementById("strip-snap-gutter-tolerance");
      if (tol) tol.value = String(snapConfig.gutter_tolerance);
      // Min gutter width
      const mgw = document.getElementById("strip-snap-min-gutter-width");
      if (mgw) mgw.value = String(snapConfig.min_gutter_width);
      // Merge close gutters
      const mrg = document.getElementById("strip-snap-gutter-merge-gap");
      if (mrg) mrg.value = String(snapConfig.gutter_merge_gap ?? 0);

      // Page padding slider + label
      const padSlider = document.getElementById("strip-page-padding-slider");
      const padLabel  = document.getElementById("strip-page-padding-label");
      if (padSlider) padSlider.value = String(currentPadding);
      if (padLabel)  padLabel.textContent = currentPadding + "%";

      // Snap debugger toggle
      const dbgToggle = document.getElementById("strip-snap-debug-toggle");
      if (dbgToggle) dbgToggle.checked = snapDebugOn;

      // Tap zone preset card highlight
      document.querySelectorAll(".strip-tap-preset-card").forEach((card) => {
        const active = card.dataset.preset === tapPreset;
        card.classList.toggle("border-primary", active);
        card.classList.toggle("bg-primary/5",    active);
        card.classList.toggle("border-base-content/20", !active);
        const radio = card.querySelector('input[type="radio"]');
        if (radio) radio.checked = active;
      });
    }

    function openSettings() {
      if (!modal) return;
      syncSettingsUI();
      modal.showModal();
    }
    document.getElementById("strip-settings-btn-mobile")?.addEventListener("click", openSettings);
    document.getElementById("strip-settings-btn-desktop")?.addEventListener("click", openSettings);

    // ── Comments-visible toggle ──────────────────────────────────
    // Mirrors the paged reader: every control (nav buttons mobile +
    // desktop, settings checkbox) routes through setStripCommentsVisible
    // so state stays in lockstep and the choice persists via
    // /comments_visible PUT for cross-device sync.
    function applyStripCommentsVisible() {
      const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
      if (layer?.setVisible) layer.setVisible(commentsVisible);
      document.querySelectorAll(
        "#strip-comments-toggle-mobile, #strip-comments-toggle-desktop"
      ).forEach((btn) => btn.classList.toggle("btn-active", commentsVisible));
      const cv = document.getElementById("strip-comments-visible");
      if (cv) cv.checked = commentsVisible;
    }
    function setStripCommentsVisible(next) {
      const val = !!next;
      if (val === commentsVisible) return;
      commentsVisible = val;
      localStorage.setItem(COMMENTS_VISIBLE_KEY, val ? "true" : "false");
      applyStripCommentsVisible();
      fetch(`${SHELL.dataset.settingsBase}/comments_visible`, {
        method: "PUT",
        headers: {
          "content-type": "application/json",
          "x-csrf-token": SHELL.dataset.csrfToken
        },
        credentials: "same-origin",
        body: JSON.stringify({ visible: val })
      }).catch(() => {});
    }
    function whenStripEtcherReady(cb, attempts) {
      attempts = attempts || 0;
      const layer = window.Etcher?.layerFor?.("fresco-strip-reader");
      if (layer) cb(layer);
      else if (attempts < 50) setTimeout(() => whenStripEtcherReady(cb, attempts + 1), 100);
    }
    whenStripEtcherReady(() => applyStripCommentsVisible());

    document.getElementById("strip-comments-toggle-mobile")?.addEventListener(
      "click", () => setStripCommentsVisible(!commentsVisible)
    );
    document.getElementById("strip-comments-toggle-desktop")?.addEventListener(
      "click", () => setStripCommentsVisible(!commentsVisible)
    );
    document.getElementById("strip-comments-visible")?.addEventListener("change", (e) => {
      setStripCommentsVisible(!!e.target.checked);
    });

    document.getElementById("strip-panel-snap-toggle")?.addEventListener("change", (e) => {
      panelSnapEnabled = !!e.target.checked;
      localStorage.setItem(SNAP_ON_KEY, panelSnapEnabled ? "true" : "false");
      syncSettingsUI();
      window.__stripFlushSnapQueue?.();
      window.__stripRebuildSnapQueue?.();
    });

    // ── Snap-config changes (persist + apply) ────────────────────
    function updateSnapConfig(patch, opts) {
      snapConfig = Object.assign({}, snapConfig, patch);
      saveSnapConfig(snapConfig);
      // If a setting that affects detection changed, clear the cache
      // so the new value takes effect on the next scan.
      if (opts && opts.invalidateCache) {
        gutterCache.clear();
        detecting.clear();
      }
      syncSettingsUI();
      // Different knobs = different targets — rebuild the predictive
      // queue under the new config.
      window.__stripFlushSnapQueue?.();
      window.__stripRebuildSnapQueue?.();
    }
    document.querySelectorAll(".strip-snap-jump-btn").forEach((btn) => {
      btn.addEventListener("click", () => updateSnapConfig({ jump_style: btn.dataset.value }));
    });
    document.getElementById("strip-snap-scan-distance")?.addEventListener("change", (e) => {
      updateSnapConfig({ scan_distance: parseInt(e.target.value, 10) || 3 });
    });
    document.getElementById("strip-snap-long-panel-steps")?.addEventListener("change", (e) => {
      updateSnapConfig({ long_panel_steps: !!e.target.checked });
    });
    document.getElementById("strip-snap-gutter-tolerance")?.addEventListener("change", (e) => {
      updateSnapConfig({ gutter_tolerance: parseInt(e.target.value, 10) || 300 }, { invalidateCache: true });
    });
    document.getElementById("strip-snap-min-gutter-width")?.addEventListener("change", (e) => {
      updateSnapConfig({ min_gutter_width: parseInt(e.target.value, 10) || 50 }, { invalidateCache: true });
    });
    document.getElementById("strip-snap-gutter-merge-gap")?.addEventListener("change", (e) => {
      updateSnapConfig({ gutter_merge_gap: parseInt(e.target.value, 10) || 0 }, { invalidateCache: true });
    });
    document.getElementById("strip-snap-config-reset")?.addEventListener("click", () => {
      snapConfig = { ...DEFAULT_SNAP_CONFIG };
      saveSnapConfig(snapConfig);
      gutterCache.clear();
      detecting.clear();
      syncSettingsUI();
      window.__stripFlushSnapQueue?.();
      window.__stripRebuildSnapQueue?.();
    });

    // ── Tap-zone preset ──────────────────────────────────────────
    // Mirrors the paged reader: change the preset, close the
    // settings modal, then flash the four zones with their action
    // color so the user can see what each region does at a glance.
    const STRIP_TAP_OVERLAY = document.getElementById("strip-tap-zone-overlay");
    const STRIP_ZONE_STYLES = {
      next: { bg: "rgba(34,197,94,0.3)",  border: "rgba(34,197,94,0.4)",  color: "#14532d" },
      prev: { bg: "rgba(239,68,68,0.3)",  border: "rgba(239,68,68,0.4)",  color: "#7f1d1d" },
      menu: { bg: "rgba(59,130,246,0.3)", border: "rgba(59,130,246,0.4)", color: "#1e3a5f" }
    };
    function stripZonePositions(rect) {
      const t = Math.max(0, rect.top), l = rect.left, w = rect.width;
      const h = Math.min(rect.bottom, window.innerHeight) - t;
      const third = w / 3;
      const vw = window.innerWidth;
      return {
        leftThird:  `top:${t}px;left:0;width:${l + third}px;height:${h}px`,
        rightThird: `top:${t}px;left:${l + third * 2}px;width:${vw - l - third * 2}px;height:${h}px`,
        midTop:     `top:${t}px;left:${l + third}px;width:${third}px;height:${h / 2}px`,
        midBottom:  `top:${t + h / 2}px;left:${l + third}px;width:${third}px;height:${h / 2}px`
      };
    }
    function flashStripTapZoneOverlay() {
      if (!STRIP_TAP_OVERLAY) return;
      // Use the viewport as the bounds since the strip fills the
      // whole window; matches what tap-zone hit-testing sees.
      const rect = {
        top: 0, left: 0,
        right: window.innerWidth, bottom: window.innerHeight,
        width: window.innerWidth, height: window.innerHeight
      };
      const preset = TAP_ZONE_PRESETS[tapPreset] || TAP_ZONE_PRESETS.default;
      const positions = stripZonePositions(rect);
      STRIP_TAP_OVERLAY.innerHTML = Object.entries(positions).map(([key, pos]) => {
        const action = preset[key];
        const s = STRIP_ZONE_STYLES[action];
        const label = action.charAt(0).toUpperCase() + action.slice(1);
        return `<div style="position:fixed;${pos};background:${s.bg};border:1px solid ${s.border};color:${s.color};display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:1.125rem">${label}</div>`;
      }).join("");
      setTimeout(() => {
        STRIP_TAP_OVERLAY.style.opacity = "1";
        setTimeout(() => { STRIP_TAP_OVERLAY.style.opacity = "0"; }, 1500);
      }, 300);
    }

    document.querySelectorAll(".strip-tap-preset-card").forEach((card) => {
      card.addEventListener("click", () => {
        tapPreset = card.dataset.preset;
        localStorage.setItem(TAP_PRESET_KEY, tapPreset);
        syncSettingsUI();
        document.getElementById("strip-settings-modal")?.close();
        flashStripTapZoneOverlay();
      });
    });

    // ── Snap debugger toggle ─────────────────────────────────────
    document.getElementById("strip-snap-debug-toggle")?.addEventListener("change", (e) => {
      snapDebugOn = !!e.target.checked;
      localStorage.setItem(DEBUG_KEY, snapDebugOn ? "true" : "false");
      // Drive the snap-target overlay too — defined inside whenReady.
      if (window.__stripSetSnapDebugOverlay) window.__stripSetSnapDebugOverlay(snapDebugOn);
    });

    // ── Page padding slider ──────────────────────────────────────
    // Live-updates as the user drags — `input` not `change` so they
    // get instant visual feedback (matches production). The apply
    // function captures scroll anchor before resize.
    document.getElementById("strip-page-padding-slider")?.addEventListener("input", (e) => {
      const pct = parseInt(e.target.value, 10);
      if (window.__stripApplyPadding) window.__stripApplyPadding(pct);
    });

    // ── Mouse-gesture (Pointer Lock) navigation ───────────────────
    // Desktop-only: click the bottom-right button → browser hides the
    // cursor and reports `movementY` deltas; we hand those to
    // `window.scrollBy` so flicking the mouse up/down scrolls the
    // strip. Click anywhere (or Escape) to release. Auto-reader, if
    // it was running, naturally pauses on the synthetic scroll
    // (same path as a real wheel scroll).
    (function setupMouseGestures() {
      const btn = document.getElementById("mouse-gesture-btn");
      const banner = document.getElementById("mouse-gesture-banner");
      if (!btn) return;
      const lockTarget = document.documentElement;
      if (!lockTarget.requestPointerLock) {
        console.warn("[mouse-gesture] Pointer Lock API unsupported");
        return;
      }

      // Snap-mode threshold: a light flick (~8px of pointer travel)
      // is enough to fire snapTo. Lower → twitchier; higher → needs
      // a bigger swing. Independent of the free-scroll speed setting.
      const SNAP_THRESHOLD_PX = 8;
      // Free-scroll mode baseline. The user's nav-bar scroll-speed
      // multiplier (turtle / rabbit) is layered on top inside
      // `onMouseMove` so the gesture honors the same setting as the
      // tap-to-snap fallback.
      const FREE_SCROLL_BASE = 1.2;
      let accumY = 0;
      let armed = false;

      // Strip mode uses an internal scroll container (#fresco-strip-reader),
      // not the window. Resolve lazily — the element exists once the
      // strip viewer mounts, which may happen after this IIFE runs.
      function scrollSurface() {
        return document.getElementById("fresco-strip-reader") || document.scrollingElement || document.documentElement;
      }

      function onMouseMove(e) {
        if (!e.movementY) return;
        const snapOn = typeof window.__stripIsSnapEnabled === "function" && window.__stripIsSnapEnabled();
        const haveSnap = typeof window.__stripSnap === "function";

        if (snapOn && haveSnap) {
          // Snap mode: accumulate vertical travel until it crosses the
          // threshold, then fire the same `snapTo` the tap-to-snap path
          // uses. While a snap is animating, DISCARD movement instead
          // of accumulating: one physical flick streams mousemove
          // events for hundreds of ms, and letting the tail accumulate
          // (or queue inside snapTo) turned a single flick into two
          // jumps. Dropping it means one flick = one snap; the next
          // flick after the animation settles fires the next one.
          if (typeof window.__stripIsSnapping === "function" && window.__stripIsSnapping()) {
            accumY = 0;
            return;
          }
          accumY += e.movementY;
          while (accumY <= -SNAP_THRESHOLD_PX) {
            window.__stripSnap(-1);
            accumY += SNAP_THRESHOLD_PX;
          }
          while (accumY >= SNAP_THRESHOLD_PX) {
            window.__stripSnap(1);
            accumY -= SNAP_THRESHOLD_PX;
          }
        } else {
          // Free-scroll: proportional to mouse movement, multiplied by
          // the navbar speed setting so turtle / rabbit feels right.
          accumY = 0;
          const mult = typeof window.__stripSpeedMultiplier === "function"
            ? window.__stripSpeedMultiplier()
            : 1;
          const delta = e.movementY * FREE_SCROLL_BASE * mult;
          const el = scrollSurface();
          if (el.scrollBy) el.scrollBy(0, delta);
          else el.scrollTop += delta;
        }
      }

      function onClick(e) {
        if (!armed) { armed = true; return; }
        if (document.pointerLockElement) {
          e.preventDefault();
          e.stopPropagation();
          document.exitPointerLock();
        }
      }

      function onLockChange() {
        const locked = !!document.pointerLockElement;
        if (locked) {
          armed = false;
          accumY = 0;
          banner?.classList.remove("hidden");
          document.addEventListener("mousemove", onMouseMove);
          document.addEventListener("click", onClick, true);
        } else {
          banner?.classList.add("hidden");
          document.removeEventListener("mousemove", onMouseMove);
          document.removeEventListener("click", onClick, true);
        }
      }

      function onLockError(e) {
        console.warn("[mouse-gesture] pointerlockerror", e);
      }

      document.addEventListener("pointerlockchange", onLockChange);
      document.addEventListener("pointerlockerror", onLockError);

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        try {
          const result = lockTarget.requestPointerLock({ unadjustedMovement: true });
          if (result && typeof result.then === "function") {
            result.catch((err) => {
              console.warn("[mouse-gesture] requestPointerLock rejected", err);
              try { lockTarget.requestPointerLock(); } catch (_) {}
            });
          }
        } catch (err) {
          console.warn("[mouse-gesture] requestPointerLock threw", err);
        }
      });

      // Middle-click (scroll-wheel button) toggles gesture mode — the
      // same gesture the OS uses for auto-scroll, which this mode
      // emulates. Interactive elements keep their native middle-click
      // behavior (links: open in new tab); elsewhere we suppress the
      // browser's autoscroll and enter the mode. Exit is explicit here
      // because a middle press fires `auxclick`, not `click`, so the
      // any-click exit handler never sees it.
      document.addEventListener("mousedown", (e) => {
        if (e.button !== 1) return;
        if (document.pointerLockElement) {
          e.preventDefault();
          document.exitPointerLock();
          return;
        }
        if (e.target.closest("a, button, input, textarea, select, dialog")) return;
        e.preventDefault();
        btn.click();
      });
    })();
  })();
</script>
